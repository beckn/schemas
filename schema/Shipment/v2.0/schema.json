{
  "type": "object",
  "title": "Shipment",
  "description": "A Shipment represents the movement of one or more packages from an origin to a destination. It is the top-level fulfillment entity in a logistics transaction and maps to beckn:Fulfillment.\n",
  "required": [
    "id",
    "status",
    "origin",
    "destination"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the shipment",
      "example": "SHP-2024-001234"
    },
    "trackingId": {
      "type": "string",
      "description": "Public tracking identifier shared with sender/receiver",
      "example": "TRK9876543210IN"
    },
    "status": {
      "type": "string",
      "description": "Current status of the shipment",
      "enum": [
        "CREATED",
        "PICKUP_PENDING",
        "PICKED_UP",
        "IN_TRANSIT",
        "AT_HUB",
        "OUT_FOR_DELIVERY",
        "DELIVERED",
        "FAILED_DELIVERY",
        "RETURNED",
        "CANCELLED"
      ],
      "example": "IN_TRANSIT"
    },
    "origin": {
      "$ref": "https://schema.beckn.io/Place/attributes.yaml"
    },
    "destination": {
      "$ref": "https://schema.beckn.io/Place/attributes.yaml"
    },
    "packages": {
      "type": "array",
      "description": "List of packages in this shipment",
      "items": {
        "$ref": "https://schema.beckn.io/Package/attributes.yaml"
      }
    },
    "carrier": {
      "$ref": "https://schema.beckn.io/Carrier/attributes.yaml"
    },
    "driver": {
      "$ref": "https://schema.beckn.io/Driver/attributes.yaml"
    },
    "vehicle": {
      "$ref": "https://schema.beckn.io/Vehicle/attributes.yaml"
    },
    "route": {
      "$ref": "https://schema.beckn.io/Route/attributes.yaml"
    },
    "scheduledPickup": {
      "type": "string",
      "format": "date-time",
      "description": "Scheduled pickup time"
    },
    "estimatedDelivery": {
      "type": "string",
      "format": "date-time",
      "description": "Estimated delivery date and time"
    },
    "actualDelivery": {
      "type": "string",
      "format": "date-time",
      "description": "Actual delivery date and time"
    },
    "deliverySlot": {
      "$ref": "https://schema.beckn.io/DeliverySlot/attributes.yaml"
    },
    "serviceType": {
      "type": "string",
      "description": "Type of logistics service",
      "enum": [
        "HYPERLOCAL",
        "COURIER",
        "INTERSTATE",
        "LONG_HAUL",
        "EXPRESS"
      ],
      "example": "EXPRESS"
    },
    "specialInstructions": {
      "type": "string",
      "description": "Special handling instructions for the shipment",
      "example": "Handle with care. Do not tilt."
    },
    "proof": {
      "$ref": "https://schema.beckn.io/Proof/attributes.yaml"
    },
    "fare": {
      "$ref": "https://schema.beckn.io/Fare/attributes.yaml"
    },
    "receipt": {
      "$ref": "https://schema.beckn.io/Receipt/attributes.yaml"
    },
    "cancellationPolicy": {
      "$ref": "https://schema.beckn.io/CancellationPolicy/attributes.yaml"
    },
    "returnPolicy": {
      "$ref": "https://schema.beckn.io/ReturnPolicy/attributes.yaml"
    },
    "alerts": {
      "type": "array",
      "description": "Alerts raised for this shipment",
      "items": {
        "$ref": "https://schema.beckn.io/Alert/attributes.yaml"
      }
    },
    "trackingUpdates": {
      "type": "array",
      "description": "History of tracking updates",
      "items": {
        "$ref": "https://schema.beckn.io/TrackingUpdate/attributes.yaml"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when shipment was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of last update"
    }
  },
  "$id": "https://schema.beckn.io/Shipment/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
