{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "cpra": "https://schema.beckn.io/CandidateProfileResourceAttributes#",
    "se": "https://schema.beckn.io/SkillEntry#",
    "cpra:skills": {
      "@id": "cpra:skills",
      "@container": "@list"
    },
    "cpra:experienceLevel": {
      "@id": "cpra:experienceLevel"
    },
    "cpra:experienceYears": {
      "@id": "cpra:experienceYears"
    },
    "cpra:locationPreference": {
      "@id": "cpra:locationPreference"
    },
    "cpra:preferredLocations": {
      "@id": "cpra:preferredLocations",
      "@container": "@list"
    },
    "cpra:workModePreference": {
      "@id": "cpra:workModePreference"
    },
    "cpra:availability": {
      "@id": "cpra:availability"
    },
    "cpra:openToRelocation": {
      "@id": "cpra:openToRelocation"
    },
    "cpra:industryPreference": {
      "@id": "cpra:industryPreference",
      "@container": "@list"
    },
    "cpra:jobTypePreference": {
      "@id": "cpra:jobTypePreference",
      "@container": "@list"
    },
    "cpra:overallVerificationStatus": {
      "@id": "cpra:overallVerificationStatus"
    },
    "se:category": {
      "@id": "se:category"
    },
    "se:subtype": {
      "@id": "se:subtype"
    },
    "se:level": {
      "@id": "se:level"
    },
    "se:attested": {
      "@id": "se:attested"
    },
    "se:proofRequestUrl": {
      "@id": "se:proofRequestUrl",
      "@type": "@id"
    },
    "schema:addressLocality": {
      "@id": "schema:addressLocality"
    },
    "schema:addressRegion": {
      "@id": "schema:addressRegion"
    },
    "schema:addressCountry": {
      "@id": "schema:addressCountry"
    },
    "skills": "beckn:skills",
    "experience_level": "beckn:experience_level",
    "experience_years": "beckn:experience_years",
    "location_preference": "beckn:location_preference",
    "availability": "beckn:availability",
    "open_to_relocation": "beckn:open_to_relocation",
    "industry_preference": "beckn:industry_preference",
    "job_type_preference": "beckn:job_type_preference",
    "overall_verification_status": "beckn:overall_verification_status",
    "Availability": "cpra:Availability",
    "ExperienceLevel": "cpra:ExperienceLevel",
    "VerificationStatus": "cpra:VerificationStatus",
    "CandidateProfileResourceAttributes": "beckn:CandidateProfileResourceAttributes",
    "city": "beckn:city",
    "country": "beckn:country",
    "preferred_locations": "beckn:preferred_locations",
    "region": "beckn:region",
    "work_mode_preference": "beckn:work_mode_preference"
  }
}
