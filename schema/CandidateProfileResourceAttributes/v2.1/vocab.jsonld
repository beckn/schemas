{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/vocab.jsonld",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "cpra": "https://schema.beckn.io/CandidateProfileResourceAttributes#"
  },
  "@graph": [
    {
      "@id": "cpra:ExperienceLevel",
      "@type": "rdfs:Class",
      "rdfs:label": "Experience Level",
      "rdfs:comment": "Overall seniority level of a candidate."
    },
    { "@id": "cpra:ENTRY",  "@type": "cpra:ExperienceLevel", "rdfs:label": "Entry Level",  "rdfs:comment": "Candidate with less than 1 year of experience or a fresh graduate." },
    { "@id": "cpra:JUNIOR", "@type": "cpra:ExperienceLevel", "rdfs:label": "Junior",       "rdfs:comment": "Candidate with 1–3 years of experience." },
    { "@id": "cpra:MID",    "@type": "cpra:ExperienceLevel", "rdfs:label": "Mid-Level",    "rdfs:comment": "Candidate with 3–6 years of experience." },
    { "@id": "cpra:SENIOR", "@type": "cpra:ExperienceLevel", "rdfs:label": "Senior",       "rdfs:comment": "Candidate with 6–10 years of experience." },
    { "@id": "cpra:EXPERT", "@type": "cpra:ExperienceLevel", "rdfs:label": "Expert",       "rdfs:comment": "Candidate with 10+ years or domain authority." },
    {
      "@id": "cpra:Availability",
      "@type": "rdfs:Class",
      "rdfs:label": "Availability",
      "rdfs:comment": "How soon a candidate is available to start a new role."
    },
    { "@id": "cpra:IMMEDIATE",      "@type": "cpra:Availability", "rdfs:label": "Immediate",         "rdfs:comment": "Available to start immediately." },
    { "@id": "cpra:WITHIN_30_DAYS", "@type": "cpra:Availability", "rdfs:label": "Within 30 Days",    "rdfs:comment": "Available to start within 30 days." },
    { "@id": "cpra:WITHIN_60_DAYS", "@type": "cpra:Availability", "rdfs:label": "Within 60 Days",    "rdfs:comment": "Available to start within 60 days." },
    { "@id": "cpra:WITHIN_90_DAYS", "@type": "cpra:Availability", "rdfs:label": "Within 90 Days",    "rdfs:comment": "Available to start within 90 days." },
    { "@id": "cpra:NOT_AVAILABLE",  "@type": "cpra:Availability", "rdfs:label": "Not Available",      "rdfs:comment": "Currently not available for new roles." },
    {
      "@id": "cpra:VerificationStatus",
      "@type": "rdfs:Class",
      "rdfs:label": "Verification Status",
      "rdfs:comment": "Aggregate VC attestation coverage for a candidate profile."
    },
    { "@id": "cpra:UNVERIFIED",         "@type": "cpra:VerificationStatus", "rdfs:label": "Unverified",         "rdfs:comment": "No VC-backed skills in the profile." },
    { "@id": "cpra:PARTIALLY_VERIFIED", "@type": "cpra:VerificationStatus", "rdfs:label": "Partially Verified", "rdfs:comment": "Some skills are VC-backed; others are self-declared." },
    { "@id": "cpra:FULLY_VERIFIED",     "@type": "cpra:VerificationStatus", "rdfs:label": "Fully Verified",     "rdfs:comment": "All declared skills are VC-backed." }
  ]
}
