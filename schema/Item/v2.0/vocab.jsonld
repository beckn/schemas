{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Item",
            "@type": "rdfs:Class",
            "rdfs:label": "Item",
            "rdfs:comment": "A sellable item or service entry in a catalog."
        },
        {
            "@id": "beckn:acceptedPaymentMethod",
            "@type": "rdf:Property",
            "rdfs:label": "Accepted payment method",
            "rdfs:comment": "Payment methods accepted for this entity.",
            "rdfs:domain": [
                "beckn:Offer",
                "beckn:Item",
                "beckn:Payment"
            ],
            "schema:rangeIncludes": "beckn:AcceptedPaymentMethod"
        },
        {
            "@id": "beckn:addOnItems",
            "@type": "rdf:Property",
            "rdfs:label": "Add-on items",
            "rdfs:comment": "Optional extras modeled as items.",
            "rdfs:domain": "beckn:Offer",
            "rdfs:range": "beckn:Item"
        },
        {
            "@id": "beckn:alertDescriptor",
            "rdfs:label": "Alert descriptor",
            "rdfs:comment": "Scoped descriptor for Alert metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Alert",
            "schema:rangeIncludes": "beckn:AlertDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:availabilityWindow",
            "@type": "rdf:Property",
            "rdfs:label": "Availability window",
            "rdfs:comment": "Time periods when the item is available.",
            "rdfs:domain": "beckn:Item",
            "rdfs:range": "beckn:TimePeriod"
        },
        {
            "@id": "beckn:availableAt",
            "@type": "rdf:Property",
            "rdfs:label": "Available at",
            "rdfs:comment": "Physical locations where the item is available.",
            "rdfs:domain": "beckn:Item",
            "rdfs:range": "beckn:Location"
        },
        {
            "@id": "beckn:cancellationPolicyDescriptor",
            "rdfs:label": "CancellationPolicy descriptor",
            "rdfs:comment": "Scoped descriptor for CancellationPolicy metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:CancellationPolicy",
            "schema:rangeIncludes": "beckn:CancellationPolicyDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:catalogDescriptor",
            "rdfs:label": "Catalog descriptor",
            "rdfs:comment": "Scoped descriptor for Catalog metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Catalog",
            "schema:rangeIncludes": "beckn:CatalogDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:category",
            "@type": "rdf:Property",
            "rdfs:label": "Category",
            "rdfs:comment": "Category or taxonomy classification.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": [
                "beckn:CategoryCode",
                "schema:Text"
            ]
        },
        {
            "@id": "beckn:constraintDescriptor",
            "rdfs:label": "Constraint descriptor",
            "rdfs:comment": "Scoped descriptor for Constraint metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Constraint",
            "schema:rangeIncludes": "beckn:ConstraintDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:constraints",
            "@type": "rdf:Property",
            "rdfs:label": "Constraints",
            "rdfs:comment": "Constraints/limits applicable to an item or offer.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": "beckn:Constraint"
        },
        {
            "@id": "beckn:credentialDescriptor",
            "rdfs:label": "Credential descriptor",
            "rdfs:comment": "Scoped descriptor for Credential metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Credential",
            "schema:rangeIncludes": "beckn:CredentialDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:descriptor",
            "@type": "rdf:Property",
            "rdfs:label": "Descriptor",
            "rdfs:comment": "Human or agent-readable description of anything for display or context setting.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider"
            ],
            "schema:rangeIncludes": "beckn:Descriptor"
        },
        {
            "@id": "beckn:entitlementDescriptor",
            "rdfs:label": "Entitlement descriptor",
            "rdfs:comment": "Scoped descriptor for Entitlement metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Entitlement",
            "schema:rangeIncludes": "beckn:EntitlementDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:features",
            "@type": "rdf:Property",
            "rdfs:label": "Features",
            "rdfs:comment": "Features/capabilities applicable to an entity.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Feature"
        },
        {
            "@id": "beckn:fulfillmentAgentDescriptor",
            "rdfs:label": "FulfillmentAgent descriptor",
            "rdfs:comment": "Scoped descriptor for FulfillmentAgent metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:FulfillmentAgent",
            "schema:rangeIncludes": "beckn:FulfillmentAgentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillmentDescriptor",
            "rdfs:label": "Fulfillment descriptor",
            "rdfs:comment": "Scoped descriptor for Fulfillment metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Fulfillment",
            "schema:rangeIncludes": "beckn:FulfillmentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillmentStateDescriptor",
            "rdfs:label": "FulfillmentState descriptor",
            "rdfs:comment": "Scoped descriptor for FulfillmentState metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:FulfillmentState",
            "schema:rangeIncludes": "beckn:FulfillmentStateDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:id",
            "@type": "rdf:Property",
            "rdfs:label": "Identifier",
            "rdfs:comment": "Primary identifier (string/URN) for an entity.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider",
                "beckn:Order",
                "beckn:Fulfillment",
                "beckn:Payment",
                "beckn:Buyer",
                "beckn:Descriptor",
                "beckn:Location",
                "beckn:Invoice",
                "beckn:Rating",
                "beckn:SupportInfo",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:instructionDescriptor",
            "rdfs:label": "Instruction descriptor",
            "rdfs:comment": "Scoped descriptor for Instruction metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Instruction",
            "schema:rangeIncludes": "beckn:InstructionDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:invoiceDescriptor",
            "rdfs:label": "Invoice descriptor",
            "rdfs:comment": "Scoped descriptor for Invoice metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Invoice",
            "schema:rangeIncludes": "beckn:InvoiceDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:isActive",
            "@type": "rdf:Property",
            "rdfs:label": "Is Active",
            "rdfs:comment": "Whether the entity is currently active for ordering.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": "schema:Boolean"
        },
        {
            "@id": "beckn:itemAttributes",
            "@type": "rdf:Property",
            "rdfs:label": "Item attributes",
            "rdfs:comment": "Domain-specific attribute pack for the item.",
            "rdfs:domain": "beckn:Item",
            "schema:rangeIncludes": "beckn:Attributes"
        },
        {
            "@id": "beckn:itemDescriptor",
            "rdfs:label": "Item descriptor",
            "rdfs:comment": "Scoped descriptor for Item metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Item",
            "schema:rangeIncludes": "beckn:ItemDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:items",
            "@type": "rdf:Property",
            "rdfs:label": "Items",
            "rdfs:comment": "List of item identifiers or references.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Offer",
                "beckn:Order"
            ],
            "rdfs:range": "beckn:Item"
        },
        {
            "@id": "beckn:locationDescriptor",
            "rdfs:label": "Location descriptor",
            "rdfs:comment": "Scoped descriptor for Location metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Location",
            "schema:rangeIncludes": "beckn:LocationDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:networkId",
            "@type": "rdf:Property",
            "rdfs:label": "Network ID",
            "rdfs:comment": "A unique identifier representing a group of platforms. By default, it is the url of the network registry on the Beckn network",
            "rdfs:domain": [
                "beckn:Context",
                "beckn:Item"
            ],
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:offerDescriptor",
            "rdfs:label": "Offer descriptor",
            "rdfs:comment": "Scoped descriptor for Offer metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Offer",
            "schema:rangeIncludes": "beckn:OfferDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:orderDescriptor",
            "rdfs:label": "Order descriptor",
            "rdfs:comment": "Scoped descriptor for Order metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Order",
            "schema:rangeIncludes": "beckn:OrderDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:orderItemDescriptor",
            "rdfs:label": "OrderItem descriptor",
            "rdfs:comment": "Scoped descriptor for OrderItem metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:OrderItem",
            "schema:rangeIncludes": "beckn:OrderItemDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:orderedItem",
            "@type": "rdf:Property",
            "rdfs:label": "Ordered item",
            "rdfs:comment": "Catalog item referenced in the order line.",
            "rdfs:domain": "beckn:OrderItem",
            "schema:rangeIncludes": [
                "beckn:Item",
                "schema:Text"
            ]
        },
        {
            "@id": "beckn:participantDescriptor",
            "rdfs:label": "Participant descriptor",
            "rdfs:comment": "Scoped descriptor for Participant metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Participant",
            "schema:rangeIncludes": "beckn:ParticipantDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:paymentDescriptor",
            "rdfs:label": "Payment descriptor",
            "rdfs:comment": "Scoped descriptor for Payment metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Payment",
            "schema:rangeIncludes": "beckn:PaymentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:policies",
            "@type": "rdf:Property",
            "rdfs:label": "Policies",
            "rdfs:comment": "Policies applicable to an entity.",
            "rdfs:domain": [
                "beckn:Provider",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Order",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Policy"
        },
        {
            "@id": "beckn:policyDescriptor",
            "rdfs:label": "Policy descriptor",
            "rdfs:comment": "Scoped descriptor for Policy metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Policy",
            "schema:rangeIncludes": "beckn:PolicyDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:provider",
            "@type": "rdf:Property",
            "rdfs:label": "Provider",
            "rdfs:comment": "Provider associated with a catalog, item or order.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Order"
            ],
            "schema:rangeIncludes": "beckn:Provider"
        },
        {
            "@id": "beckn:providerDescriptor",
            "rdfs:label": "Provider descriptor",
            "rdfs:comment": "Scoped descriptor for Provider metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Provider",
            "schema:rangeIncludes": "beckn:ProviderDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:rateable",
            "@type": "rdf:Property",
            "rdfs:label": "Rateable",
            "rdfs:comment": "Whether the entity can be rated by customers.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Provider"
            ],
            "schema:rangeIncludes": "schema:Boolean"
        },
        {
            "@id": "beckn:rating",
            "@type": "rdf:Property",
            "rdfs:label": "Rating",
            "rdfs:comment": "Rating summary for the entity.",
            "rdfs:domain": [
                "beckn:Item",
                "beckn:Provider"
            ],
            "schema:rangeIncludes": "beckn:Rating"
        },
        {
            "@id": "beckn:skillDescriptor",
            "rdfs:label": "Skill descriptor",
            "rdfs:comment": "Scoped descriptor for Skill metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Skill",
            "schema:rangeIncludes": "beckn:SkillDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:stateDescriptor",
            "rdfs:label": "State descriptor",
            "rdfs:comment": "Scoped descriptor for State metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:State",
            "schema:rangeIncludes": "beckn:StateDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:supportInfoDescriptor",
            "rdfs:label": "SupportInfo descriptor",
            "rdfs:comment": "Scoped descriptor for SupportInfo metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:SupportInfo",
            "schema:rangeIncludes": "beckn:SupportInfoDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        }
    ]
}