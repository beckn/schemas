{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:FulfillmentStageEndpoint",
            "rdfs:label": "Fulfillment Stage Endpoint",
            "@type": "rdfs:Class",
            "rdfs:comment": "A stage boundary endpoint (entry or exit) within a fulfillment, such as pickup, handover, warehouse in/out, border crossing, gate entry/exit, security check, etc. May require one or more proofs/permits/tokens/documents.\n"
        },
        {
            "@id": "beckn:authorization",
            "rdfs:label": "authorization",
            "rdfs:domain": [
                "beckn:FulfillmentStageEndpoint"
            ],
            "schema:rangeIncludes": "beckn:FulfillmentStageAuthorization",
            "@type": "rdf:Property",
            "rdfs:comment": "One or more credentials required and/or issued at this endpoint. Includes machine-readable tokens (QR/URL/OTP) and manual documents (IDs, permits).\n"
        },
        {
            "@id": "beckn:time",
            "rdfs:label": "time",
            "rdfs:domain": [
                "beckn:FulfillmentStageEndpoint"
            ],
            "schema:rangeIncludes": "beckn:Time",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        }
    ]
}