{
  "@context": {
    "beckn": "https://schema.beckn.io/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@graph": [
    {
      "@id": "beckn:Pagination",
      "@type": "rdfs:Class",
      "rdfs:label": "Pagination",
      "rdfs:comment": "Pagination metadata returned with list responses\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:count",
      "@type": "rdf:Property",
      "rdfs:label": "count",
      "rdfs:comment": "Number of items in this page"
    },
    {
      "@id": "beckn:limit",
      "@type": "rdf:Property",
      "rdfs:label": "limit",
      "rdfs:comment": "Page size used in this response"
    },
    {
      "@id": "beckn:offset",
      "@type": "rdf:Property",
      "rdfs:label": "offset",
      "rdfs:comment": "Zero-based offset used in this response"
    }
  ]
}
