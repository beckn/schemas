    {
      "@id": "beckn:sla",
      "@type": "schema:Property",
      "rdfs:label": "Sla",
      "rdfs:comment": "Service level agreement for fulfillment. Indicates expected time bounds from defined lifecycle event."
    },
    {
      "@id": "beckn:minDuration",
      "@type": "schema:Property",
      "rdfs:label": "Min Duration",
      "rdfs:comment": "Minimum fulfillment time (ISO 8601 duration)."
    },
    {
      "@id": "beckn:maxDuration",
      "@type": "schema:Property",
      "rdfs:label": "Max Duration",
      "rdfs:comment": "Maximum fulfillment time (ISO 8601 duration)."
    },
    {
      "@id": "beckn:unitBasis",
      "@type": "schema:Property",
      "rdfs:label": "Unit Basis",
      "rdfs:comment": "Lifecycle event from which SLA is measured."
    },
    {
