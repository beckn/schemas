{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RetailCoreItemAttributes": "beckn:RetailCoreItemAttributes",
    "@type": "beckn:@type",
    "additives": "beckn:additives",
    "address": "beckn:address",
    "appearance": "beckn:appearance",
    "brand": "beckn:brand",
    "breadth": "beckn:breadth",
    "classification": "beckn:classification",
    "color": "beckn:color",
    "commonOrGenericName": "beckn:commonOrGenericName",
    "credentials": "beckn:credentials",
    "dimensions": "beckn:dimensions",
    "finish": "beckn:finish",
    "food": "beckn:food",
    "foodRegulatoryDeclaration": "beckn:foodRegulatoryDeclaration",
    "height": "beckn:height",
    "id": "beckn:id",
    "identity": "beckn:identity",
    "issuer": "beckn:issuer",
    "length": "beckn:length",
    "manufacturePackingImportDate": "beckn:manufacturePackingImportDate",
    "manufacturerOrPacker": "beckn:manufacturerOrPacker",
    "material": "beckn:material",
    "month": "beckn:month",
    "name": "beckn:name",
    "netQuantity": "beckn:netQuantity",
    "notes": "beckn:notes",
    "originCountry": "beckn:originCountry",
    "packagedGoodsDeclaration": "beckn:packagedGoodsDeclaration",
    "physical": "beckn:physical",
    "quantity": "beckn:quantity",
    "registrations": "beckn:registrations",
    "role": "beckn:role",
    "scheme": "beckn:scheme",
    "type": "beckn:type",
    "unit": "beckn:unit",
    "uri": "beckn:uri",
    "url": "beckn:url",
    "value": "beckn:value",
    "volume": "beckn:volume",
    "weight": "beckn:weight",
    "year": "beckn:year"
  },
  "@graph": [
    {
      "@id": "beckn:RetailCoreItemAttributes",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Core Item Attributes",
      "rdfs:comment": "Retail-specific item attribute pack for use as Item.itemAttributes in retail domain transactions."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "JSON-LD context URI."
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "JSON-LD type identifier."
    },
    {
      "@id": "beckn:identity",
      "@type": "rdf:Property",
      "rdfs:label": "identity",
      "rdfs:comment": "Brand and origin information for the item."
    },
    {
      "@id": "beckn:physical",
      "@type": "rdf:Property",
      "rdfs:label": "physical",
      "rdfs:comment": "Weight, volume, dimensions, and appearance of the item."
    },
    {
      "@id": "beckn:food",
      "@type": "rdf:Property",
      "rdfs:label": "food",
      "rdfs:comment": "Food classification such as VEG, NON_VEG, or EGG."
    },
    {
      "@id": "beckn:packagedGoodsDeclaration",
      "@type": "rdf:Property",
      "rdfs:label": "packaged Goods Declaration",
      "rdfs:comment": "Jurisdiction-neutral packaged goods declaration for the item."
    },
    {
      "@id": "beckn:foodRegulatoryDeclaration",
      "@type": "rdf:Property",
      "rdfs:label": "food Regulatory Declaration",
      "rdfs:comment": "Jurisdiction-neutral food regulatory declarations for the item."
    },
    {
      "@id": "beckn:credentials",
      "@type": "rdf:Property",
      "rdfs:label": "credentials",
      "rdfs:comment": "External verifiable credentials or attestations associated with the item."
    }
  ]
}
