{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:CatalogProcessingResult",
            "rdfs:label": "Catalog Processing Result",
            "@type": "rdfs:Class",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:catalogId",
            "rdfs:label": "catalog Id",
            "rdfs:domain": [
                "beckn:CatalogProcessingResult"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "The \"id\" of the submitted catalog"
        },
        {
            "@id": "beckn:error",
            "rdfs:label": "error",
            "rdfs:domain": [
                "beckn:AckResponse",
                "beckn:CatalogProcessingResult",
                "beckn:ErrorResponse"
            ],
            "schema:rangeIncludes": "beckn:Error",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:itemCount",
            "rdfs:label": "item Count",
            "rdfs:domain": [
                "beckn:CatalogProcessingResult"
            ],
            "schema:rangeIncludes": "schema:Integer",
            "@type": "rdf:Property",
            "rdfs:comment": "Number of items indexed (when accepted/partial)"
        },
        {
            "@id": "beckn:status",
            "rdfs:label": "status",
            "rdfs:domain": [
                "beckn:CatalogProcessingResult"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Final processing outcome for this catalog"
        },
        {
            "@id": "beckn:warnings",
            "rdfs:label": "warnings",
            "rdfs:domain": [
                "beckn:CatalogProcessingResult"
            ],
            "schema:rangeIncludes": "beckn:ProcessingNotice",
            "@type": "rdf:Property",
            "rdfs:comment": "Non-fatal issues encountered"
        }
    ]
}