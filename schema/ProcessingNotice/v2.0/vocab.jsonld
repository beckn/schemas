{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:ProcessingNotice",
            "rdfs:label": "Processing Notice",
            "@type": "rdfs:Class",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:code",
            "rdfs:label": "code",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Error code"
        },
        {
            "@id": "beckn:details",
            "rdfs:label": "details",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Thing",
            "@type": "rdf:Property",
            "rdfs:comment": "Additional error details"
        },
        {
            "@id": "beckn:message",
            "rdfs:label": "message",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Human-readable error message"
        },
        {
            "@id": "beckn:warnings",
            "rdfs:label": "warnings",
            "rdfs:domain": [
                "beckn:CatalogProcessingResult"
            ],
            "schema:rangeIncludes": "beckn:ProcessingNotice",
            "@type": "rdf:Property",
            "rdfs:comment": "Non-fatal issues encountered"
        }
    ]
}