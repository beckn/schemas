{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:PaymentTrigger",
            "rdfs:label": "Payment Trigger",
            "@type": "schema:Enumeration",
            "rdfs:comment": "Describes when in the order lifecycle a payment flow should be triggered. Typically useful for initiating checkouts and settlement flows."
        },
        {
            "@id": "beckn:checkoutTrigger",
            "rdfs:label": "checkout Trigger",
            "rdfs:domain": [
                "beckn:PaymentTerms"
            ],
            "schema:rangeIncludes": "beckn:PaymentTrigger",
            "@type": "rdf:Property",
            "rdfs:comment": "The stage in the order lifecycle when the checkout should be triggered"
        },
        {
            "@id": "beckn:paymentTrigger",
            "rdfs:label": "payment Trigger",
            "rdfs:domain": [
                "beckn:SettlementTerm"
            ],
            "schema:rangeIncludes": "beckn:PaymentTrigger",
            "@type": "rdf:Property",
            "rdfs:comment": "Describes the event which triggers the payment against this settlement term"
        }
    ]
}