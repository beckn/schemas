{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "SettlementTerm": "beckn:SettlementTerm",
        "acceptedPaymentMethods": {
            "@id": "beckn:acceptedPaymentMethods",
            "@type": "@id",
            "@context": {
                "BANK_TRANSFER": "beckn:BankTransfer",
                "CASH_DEPOSIT": "beckn:CashDeposit"
            }
        },
        "payTo": "beckn:payTo",
        "paymentTrigger": {
            "@id": "beckn:paymentTrigger",
            "@type": "@id",
            "@context": {
                "ON_FULFILLMENT": "beckn:OnFulfillment",
                "POST_FULFILLMENT": "beckn:PostFulfillment",
                "PRE_FULFILLMENT": "beckn:PreFulfillment",
                "PRE_ORDER": "beckn:PreOrder"
            }
        },
        "settlementSchedule": "beckn:settlementSchedule",
        "settlementStatus": {
            "@id": "beckn:settlementStatus",
            "@type": "@id",
            "@context": {
                "PENDING": "beckn:SettlementPending",
                "COMPLETE": "beckn:SettlementComplete"
            }
        },
        "settlementTermAttributes": "beckn:settlementTermAttributes",
        "settlementTerms": "beckn:settlementTerms"
    }
}