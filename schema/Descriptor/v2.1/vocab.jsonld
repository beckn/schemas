{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Descriptor",
      "@type": "rdfs:Class",
      "rdfs:label": "Descriptor",
      "rdfs:comment": "Schema definition for Descriptor in the Beckn Protocol v2.0.1"
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "Use case specific JSON-LD context. This can change from use case to use case, even within a domain."
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "Type of the descriptor. The type can be overriden with a context-specific type"
    },
    {
      "@id": "beckn:longDesc",
      "@type": "rdf:Property",
      "rdfs:label": "long Desc",
      "rdfs:comment": "Detailed description of the item"
    },
    {
      "@id": "beckn:shortDesc",
      "@type": "rdf:Property",
      "rdfs:label": "short Desc",
      "rdfs:comment": "Short description of the item"
    },
    {
      "@id": "beckn:name",
      "@type": "rdf:Property",
      "rdfs:label": "name",
      "rdfs:comment": "Name of the entity being described"
    },
    {
      "@id": "beckn:thumbnailImage",
      "@type": "rdf:Property",
      "rdfs:label": "thumbnail Image",
      "rdfs:comment": "Name of the entity being described"
    },
    {
      "@id": "beckn:docs",
      "@type": "rdf:Property",
      "rdfs:label": "docs",
      "rdfs:comment": "Links to downloadable documents"
    },
    {
      "@id": "beckn:mediaFile",
      "@type": "rdf:Property",
      "rdfs:label": "media File",
      "rdfs:comment": "Links to multimedia files and images"
    }
  ]
}
