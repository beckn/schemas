{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "SpatialConstraint": "beckn:SpatialConstraint",
        "distanceMeters": "beckn:distanceMeters",
        "geometry": "beckn:geometry",
        "quantifier": {
            "@id": "beckn:quantifier",
            "@type": "@id",
            "@context": {
                "ALL": "beckn:QuantifierAll",
                "ANY": "beckn:QuantifierAny",
                "NONE": "beckn:QuantifierNone"
            }
        },
        "spatial": "beckn:spatial",
        "srid": "beckn:srid",
        "targets": "beckn:targets"
    }
}