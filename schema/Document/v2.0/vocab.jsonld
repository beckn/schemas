{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Document",
            "rdfs:label": "Document",
            "@type": "rdfs:Class",
            "rdfs:comment": "A document, that can be parsed, printed, download or displayed. This has intentionally been kept separate from MediaFile as they may contain additional attributes like signature, schema etc."
        },
        {
            "@id": "beckn:docs",
            "rdfs:label": "docs",
            "rdfs:domain": [
                "beckn:Descriptor",
                "beckn:FulfillmentStageAuthorization"
            ],
            "schema:rangeIncludes": "beckn:Document",
            "@type": "rdf:Property",
            "rdfs:comment": "Links to downloadable documents"
        },
        {
            "@id": "beckn:label",
            "rdfs:label": "label",
            "rdfs:domain": [
                "beckn:Document",
                "beckn:MediaFile"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "The display name of the media file"
        },
        {
            "@id": "beckn:mimeType",
            "@type": "rdf:Property",
            "rdfs:label": "MIME Type of a document",
            "rdfs:comment": "Mime type of a document used for parsing documents hosted at remote URLs",
            "rdfs:domain": "beckn:Document",
            "schema:rangeIncludes": "schema:CheckEquivalentInSchema.Org",
            "owl:equivalentProperty": {
                "@id": "beckn:mime_type"
            }
        },
        {
            "@id": "beckn:mime_type",
            "@type": "rdf:Property",
            "rdfs:label": "mime_type (legacy v2 IRI)",
            "rdfs:comment": "DEPRECATED: Use beckn:mimeType. This legacy snake_case IRI is retained for backward compatibility with Beckn v2.0.",
            "owl:equivalentProperty": {
                "@id": "beckn:mimeType"
            },
            "owl:deprecated": true
        },
        {
            "@id": "beckn:orderDocs",
            "rdfs:label": "order Docs",
            "rdfs:domain": [
                "beckn:Order"
            ],
            "schema:rangeIncludes": "beckn:Document",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:required",
            "rdfs:label": "required",
            "rdfs:domain": [
                "beckn:Document"
            ],
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:security",
            "rdfs:label": "security",
            "rdfs:domain": [
                "beckn:Document"
            ],
            "schema:rangeIncludes": "schema:Thing",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:standard",
            "rdfs:label": "standard",
            "rdfs:domain": [
                "beckn:Document"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Describes the schema type in case the document follows a standard schema like a verifiableCredential"
        },
        {
            "@id": "beckn:url",
            "rdfs:label": "url",
            "rdfs:domain": [
                "beckn:Document",
                "beckn:Form",
                "beckn:MediaInput",
                "beckn:SupportInfo",
                "beckn:TrackAction",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "schema:URL",
            "@type": "rdf:Property",
            "rdfs:comment": "URL to the document"
        }
    ]
}