{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Form",
            "@type": "rdfs:Class",
            "rdfs:label": "Form",
            "rdfs:comment": "A structured form for input capture in flows (e.g., init, support)."
        },
        {
            "@id": "beckn:data",
            "rdfs:label": "data",
            "rdfs:domain": [
                "beckn:Form"
            ],
            "schema:rangeIncludes": "schema:Thing",
            "@type": "rdf:Property",
            "rdfs:comment": "The form submission data"
        },
        {
            "@id": "beckn:form",
            "@type": "rdf:Property",
            "rdfs:label": "Form",
            "rdfs:comment": "Form to capture input during a flow.",
            "rdfs:domain": [
                "beckn:Order",
                "beckn:Fulfillment",
                "beckn:SupportInfo"
            ],
            "schema:rangeIncludes": "beckn:Form"
        },
        {
            "@id": "beckn:submissionId",
            "@type": "rdf:Property",
            "rdfs:label": "MIME Type of a document",
            "rdfs:comment": "The ID obtained after submitting a form on an external url",
            "rdfs:domain": "beckn:Form",
            "schema:rangeIncludes": "schema:CheckEquivalentInSchema.Org",
            "owl:equivalentProperty": {
                "@id": "beckn:submission_id"
            }
        },
        {
            "@id": "beckn:submission_id",
            "@type": "rdf:Property",
            "rdfs:label": "submission_id (legacy v2 IRI)",
            "rdfs:comment": "DEPRECATED: Use beckn:submissionId. This legacy snake_case IRI is retained for backward compatibility with Beckn v2.0.",
            "rdfs:domain": "beckn:Form",
            "owl:equivalentProperty": {
                "@id": "beckn:submissionId"
            },
            "owl:deprecated": true
        },
        {
            "@id": "beckn:url",
            "rdfs:label": "url",
            "rdfs:domain": [
                "beckn:Document",
                "beckn:Form",
                "beckn:MediaInput",
                "beckn:SupportInfo",
                "beckn:TrackAction",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "schema:URL",
            "@type": "rdf:Property",
            "rdfs:comment": "URL to the document"
        }
    ]
}