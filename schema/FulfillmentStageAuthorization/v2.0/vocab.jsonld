{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:FulfillmentStageAuthorization",
            "rdfs:label": "Fulfillment Stage Authorization",
            "@type": "rdfs:Class",
            "rdfs:comment": "A credential/document/proof relevant to authorization at a fulfillment stage endpoint. This may be a token to be verified (QR/OTP/URL) or a document to be inspected manually.\n"
        },
        {
            "@id": "beckn:authToken",
            "rdfs:label": "auth Token",
            "rdfs:domain": [
                "beckn:FulfillmentStageAuthorization"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "A human readable string that needs to be provided to enter or exit this fulfillment stage. Like an OTP"
        },
        {
            "@id": "beckn:authorization",
            "rdfs:label": "authorization",
            "rdfs:domain": [
                "beckn:FulfillmentStageEndpoint"
            ],
            "schema:rangeIncludes": "beckn:FulfillmentStageAuthorization",
            "@type": "rdf:Property",
            "rdfs:comment": "One or more credentials required and/or issued at this endpoint. Includes machine-readable tokens (QR/URL/OTP) and manual documents (IDs, permits).\n"
        },
        {
            "@id": "beckn:docs",
            "rdfs:label": "docs",
            "rdfs:domain": [
                "beckn:Descriptor",
                "beckn:FulfillmentStageAuthorization"
            ],
            "schema:rangeIncludes": "beckn:Document",
            "@type": "rdf:Property",
            "rdfs:comment": "Links to downloadable documents"
        },
        {
            "@id": "beckn:mediaFiles",
            "rdfs:label": "media Files",
            "rdfs:domain": [
                "beckn:FulfillmentStageAuthorization"
            ],
            "schema:rangeIncludes": "beckn:MediaFile",
            "@type": "rdf:Property",
            "rdfs:comment": "Media files required to enter or exit this fulfillment stage. The could be images of delivered packages, recorded video proof of installation, etc"
        }
    ]
}