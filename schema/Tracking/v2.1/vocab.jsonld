{
  "@context": {
    "beckn": "https://schema.beckn.io/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@graph": [
    {
      "@id": "beckn:Tracking",
      "@type": "rdfs:Class",
      "rdfs:label": "Tracking",
      "rdfs:comment": "Information regarding live tracking of the fufillment of a contract\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:refId",
      "@type": "rdf:Property",
      "rdfs:label": "refId",
      "rdfs:comment": "Tracking reference ID for the tracking session. Could be the Order ID, Fulfillment ID, Fulfillment Stage ID, or any other unique tracking identifier"
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": "status",
      "rdfs:comment": "Property status"
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": "url",
      "rdfs:comment": "Link/handle to off-network tracking UI or endpoint."
    }
  ]
}
