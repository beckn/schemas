{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Contract",
            "@type": "rdfs:Class",
            "rdfs:label": "Contract",
            "rdfs:comment": "A purchase contract containing items, pricing and fulfillment details."
        },
        {
            "@id": "beckn:acceptedOffers",
            "@type": "rdf:Property",
            "rdfs:label": "Accepted offers",
            "rdfs:comment": "Offers accepted as part of a contract.",
            "rdfs:domain": "beckn:Contract",
            "rdfs:range": "beckn:Offer"
        },
        {
            "@id": "beckn:alertDescriptor",
            "rdfs:label": "Alert descriptor",
            "rdfs:comment": "Scoped descriptor for Alert metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Alert",
            "schema:rangeIncludes": "beckn:AlertDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:alerts",
            "@type": "rdf:Property",
            "rdfs:label": "Alerts",
            "rdfs:comment": "Alerts applicable to a provider, contract, or fulfillment.",
            "rdfs:domain": [
                "beckn:Provider",
                "beckn:Contract",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Alert"
        },
        {
            "@id": "beckn:buyer",
            "@type": "rdf:Property",
            "rdfs:label": "Buyer (legacy v2 property)",
            "rdfs:comment": "DEPRECATED: Use beckn:consumer. Legacy v2.0 buyer property retained for backward compatibility.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:Buyer",
            "rdfs:subPropertyOf": {
                "@id": "beckn:consumer"
            },
            "owl:equivalentProperty": {
                "@id": "beckn:consumer"
            },
            "owl:deprecated": true
        },
        {
            "@id": "beckn:cancellationPolicyDescriptor",
            "rdfs:label": "CancellationPolicy descriptor",
            "rdfs:comment": "Scoped descriptor for CancellationPolicy metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:CancellationPolicy",
            "schema:rangeIncludes": "beckn:CancellationPolicyDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:catalogDescriptor",
            "rdfs:label": "Catalog descriptor",
            "rdfs:comment": "Scoped descriptor for Catalog metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Catalog",
            "schema:rangeIncludes": "beckn:CatalogDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:constraintDescriptor",
            "rdfs:label": "Constraint descriptor",
            "rdfs:comment": "Scoped descriptor for Constraint metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Constraint",
            "schema:rangeIncludes": "beckn:ConstraintDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:consumer",
            "rdfs:label": "consumer",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Consumer",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:createdAt",
            "@type": "rdf:Property",
            "rdfs:label": "Created at",
            "rdfs:comment": "Creation timestamp (UTC).",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Invoice",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": "schema:DateTime"
        },
        {
            "@id": "beckn:credentialDescriptor",
            "rdfs:label": "Credential descriptor",
            "rdfs:comment": "Scoped descriptor for Credential metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Credential",
            "schema:rangeIncludes": "beckn:CredentialDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:descriptor",
            "@type": "rdf:Property",
            "rdfs:label": "Descriptor",
            "rdfs:comment": "Human or agent-readable description of anything for display or context setting.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider"
            ],
            "schema:rangeIncludes": "beckn:Descriptor"
        },
        {
            "@id": "beckn:entitlementDescriptor",
            "rdfs:label": "Entitlement descriptor",
            "rdfs:comment": "Scoped descriptor for Entitlement metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Entitlement",
            "schema:rangeIncludes": "beckn:EntitlementDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:entitlements",
            "@type": "rdf:Property",
            "rdfs:label": "Entitlements",
            "rdfs:comment": "Entitlements issued under a contract or fulfillment.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Entitlement"
        },
        {
            "@id": "beckn:form",
            "@type": "rdf:Property",
            "rdfs:label": "Form",
            "rdfs:comment": "Form to capture input during a flow.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Fulfillment",
                "beckn:SupportInfo"
            ],
            "schema:rangeIncludes": "beckn:Form"
        },
        {
            "@id": "beckn:fulfillment",
            "@type": "rdf:Property",
            "rdfs:label": "Fulfillment",
            "rdfs:comment": "Fulfillment details for the contract.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:OrderItem"
            ],
            "rdfs:range": "beckn:Fulfillment"
        },
        {
            "@id": "beckn:fulfillmentAgentDescriptor",
            "rdfs:label": "FulfillmentAgent descriptor",
            "rdfs:comment": "Scoped descriptor for FulfillmentAgent metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:FulfillmentAgent",
            "schema:rangeIncludes": "beckn:FulfillmentAgentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillmentDescriptor",
            "rdfs:label": "Fulfillment descriptor",
            "rdfs:comment": "Scoped descriptor for Fulfillment metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Fulfillment",
            "schema:rangeIncludes": "beckn:FulfillmentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillmentStateDescriptor",
            "rdfs:label": "FulfillmentState descriptor",
            "rdfs:comment": "Scoped descriptor for FulfillmentState metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:FulfillmentState",
            "schema:rangeIncludes": "beckn:FulfillmentStateDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillments",
            "rdfs:label": "fulfillments",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Fulfillment",
            "@type": "rdf:Property",
            "rdfs:comment": "Describes various fulfillments used to deliver the contract to the consumer"
        },
        {
            "@id": "beckn:id",
            "@type": "rdf:Property",
            "rdfs:label": "Identifier",
            "rdfs:comment": "Primary identifier (string/URN) for an entity.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider",
                "beckn:Contract",
                "beckn:Fulfillment",
                "beckn:Payment",
                "beckn:Buyer",
                "beckn:Descriptor",
                "beckn:Location",
                "beckn:Invoice",
                "beckn:Rating",
                "beckn:SupportInfo",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:instructionDescriptor",
            "rdfs:label": "Instruction descriptor",
            "rdfs:comment": "Scoped descriptor for Instruction metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Instruction",
            "schema:rangeIncludes": "beckn:InstructionDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:instructions",
            "@type": "rdf:Property",
            "rdfs:label": "Instructions",
            "rdfs:comment": "Instructions applicable to an entity (e.g., stop-level access/pickup/handover instructions).",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Fulfillment",
                "beckn:FulfillmentStop",
                "beckn:Location"
            ],
            "schema:rangeIncludes": "beckn:Instruction"
        },
        {
            "@id": "beckn:invoice",
            "@type": "rdf:Property",
            "rdfs:label": "Invoice",
            "rdfs:comment": "Invoice reference/summary for the contract.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:Invoice"
        },
        {
            "@id": "beckn:invoiceDescriptor",
            "rdfs:label": "Invoice descriptor",
            "rdfs:comment": "Scoped descriptor for Invoice metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Invoice",
            "schema:rangeIncludes": "beckn:InvoiceDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:invoices",
            "rdfs:label": "invoices",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Invoice",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:itemDescriptor",
            "rdfs:label": "Item descriptor",
            "rdfs:comment": "Scoped descriptor for Item metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Item",
            "schema:rangeIncludes": "beckn:ItemDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:items",
            "@type": "rdf:Property",
            "rdfs:label": "Items",
            "rdfs:comment": "List of item identifiers or references.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Offer",
                "beckn:Contract"
            ],
            "rdfs:range": "beckn:Item"
        },
        {
            "@id": "beckn:location",
            "@type": "rdf:Property",
            "rdfs:label": "Location",
            "rdfs:comment": "Physical location or place.",
            "rdfs:domain": [
                "beckn:Provider",
                "beckn:Fulfillment",
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Location"
        },
        {
            "@id": "beckn:locationDescriptor",
            "rdfs:label": "Location descriptor",
            "rdfs:comment": "Scoped descriptor for Location metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Location",
            "schema:rangeIncludes": "beckn:LocationDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:offerDescriptor",
            "rdfs:label": "Offer descriptor",
            "rdfs:comment": "Scoped descriptor for Offer metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Offer",
            "schema:rangeIncludes": "beckn:OfferDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:contractAttributes",
            "@type": "rdf:Property",
            "rdfs:label": "Contract attributes",
            "rdfs:comment": "Contract-level attribute pack.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:Attributes"
        },
        {
            "@id": "beckn:contractDescriptor",
            "rdfs:label": "Contract descriptor",
            "rdfs:comment": "Scoped descriptor for Contract metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:ContractDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:contractDocs",
            "rdfs:label": "contract Docs",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Document",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:orderItemDescriptor",
            "rdfs:label": "OrderItem descriptor",
            "rdfs:comment": "Scoped descriptor for OrderItem metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:OrderItem",
            "schema:rangeIncludes": "beckn:OrderItemDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:contractItems",
            "@type": "rdf:Property",
            "rdfs:label": "Contract items",
            "rdfs:comment": "Items included in the contract.",
            "rdfs:domain": "beckn:Contract",
            "rdfs:range": "beckn:OrderItem"
        },
        {
            "@id": "beckn:contractNumber",
            "@type": "rdf:Property",
            "rdfs:label": "Contract number",
            "rdfs:comment": "Human-visible contract number.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:contractStatus",
            "@type": "rdf:Property",
            "rdfs:label": "Contract status",
            "rdfs:comment": "Contract status/state.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:ContractStatus"
        },
        {
            "@id": "beckn:contractValue",
            "@type": "rdf:Property",
            "rdfs:label": "Contract value",
            "rdfs:comment": "Total contract value as a price specification.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "schema:PriceSpecification"
        },
        {
            "@id": "beckn:participantDescriptor",
            "rdfs:label": "Participant descriptor",
            "rdfs:comment": "Scoped descriptor for Participant metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Participant",
            "schema:rangeIncludes": "beckn:ParticipantDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:participants",
            "@type": "rdf:Property",
            "rdfs:label": "Participants",
            "rdfs:comment": "Participants associated with a contract or fulfillment.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Participant"
        },
        {
            "@id": "beckn:payment",
            "@type": "rdf:Property",
            "rdfs:label": "Payment",
            "rdfs:comment": "Payment instrument or status for the contract.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Invoice"
            ],
            "rdfs:range": "beckn:Payment"
        },
        {
            "@id": "beckn:paymentAction",
            "rdfs:label": "payment Action",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:PaymentAction",
            "@type": "rdf:Property",
            "rdfs:comment": "Describes the act of payment"
        },
        {
            "@id": "beckn:paymentDescriptor",
            "rdfs:label": "Payment descriptor",
            "rdfs:comment": "Scoped descriptor for Payment metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Payment",
            "schema:rangeIncludes": "beckn:PaymentDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:paymentTerms",
            "rdfs:label": "payment Terms",
            "rdfs:domain": [
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:PaymentTerms",
            "@type": "rdf:Property",
            "rdfs:comment": "Terms of payment agreed upon by the buyer like source and destination accounts, beneficiary, collector, schedule, etc"
        },
        {
            "@id": "beckn:policies",
            "@type": "rdf:Property",
            "rdfs:label": "Policies",
            "rdfs:comment": "Policies applicable to an entity.",
            "rdfs:domain": [
                "beckn:Provider",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Contract",
                "beckn:Fulfillment"
            ],
            "schema:rangeIncludes": "beckn:Policy"
        },
        {
            "@id": "beckn:policyDescriptor",
            "rdfs:label": "Policy descriptor",
            "rdfs:comment": "Scoped descriptor for Policy metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Policy",
            "schema:rangeIncludes": "beckn:PolicyDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:provider",
            "@type": "rdf:Property",
            "rdfs:label": "Provider",
            "rdfs:comment": "Provider associated with a catalog, item or contract.",
            "rdfs:domain": [
                "beckn:Catalog",
                "beckn:Item",
                "beckn:Contract"
            ],
            "schema:rangeIncludes": "beckn:Provider"
        },
        {
            "@id": "beckn:providerDescriptor",
            "rdfs:label": "Provider descriptor",
            "rdfs:comment": "Scoped descriptor for Provider metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Provider",
            "schema:rangeIncludes": "beckn:ProviderDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:seller",
            "@type": "rdf:Property",
            "rdfs:label": "Seller (legacy v2 property)",
            "rdfs:comment": "DEPRECATED: Use beckn:provider. Legacy v2.0 seller property retained for backward compatibility.",
            "rdfs:domain": "beckn:Contract",
            "schema:rangeIncludes": "beckn:Provider",
            "rdfs:subPropertyOf": {
                "@id": "beckn:provider"
            },
            "owl:equivalentProperty": {
                "@id": "beckn:provider"
            },
            "owl:deprecated": true
        },
        {
            "@id": "beckn:skillDescriptor",
            "rdfs:label": "Skill descriptor",
            "rdfs:comment": "Scoped descriptor for Skill metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Skill",
            "schema:rangeIncludes": "beckn:SkillDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:state",
            "@type": "rdf:Property",
            "rdfs:label": "State",
            "rdfs:comment": "The current state of an entity.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Fulfillment",
                "beckn:Payment",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "beckn:State"
        },
        {
            "@id": "beckn:stateDescriptor",
            "rdfs:label": "State descriptor",
            "rdfs:comment": "Scoped descriptor for State metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:State",
            "schema:rangeIncludes": "beckn:StateDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:supportInfo",
            "@type": "rdf:Property",
            "rdfs:label": "Support info",
            "rdfs:comment": "Support information for the contract or provider.",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Provider"
            ],
            "schema:rangeIncludes": "beckn:SupportInfo"
        },
        {
            "@id": "beckn:supportInfoDescriptor",
            "rdfs:label": "SupportInfo descriptor",
            "rdfs:comment": "Scoped descriptor for SupportInfo metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:SupportInfo",
            "schema:rangeIncludes": "beckn:SupportInfoDescriptor",
            "rdfs:subPropertyOf": {
                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:updatedAt",
            "@type": "rdf:Property",
            "rdfs:label": "Updated at",
            "rdfs:comment": "Last update timestamp (UTC).",
            "rdfs:domain": [
                "beckn:Contract",
                "beckn:Invoice",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": "schema:DateTime"
        }
    ]
}
