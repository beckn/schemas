{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/vocab.jsonld",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "caoa": "https://schema.beckn.io/CandidateAvailabilityOfferAttributes#"
  },
  "@graph": [
    {
      "@id": "caoa:DesiredCompensationPeriod",
      "@type": "rdfs:Class",
      "rdfs:label": "Desired Compensation Period",
      "rdfs:comment": "The time unit for a candidate's stated compensation expectation."
    },
    { "@id": "caoa:ANNUAL",  "@type": "caoa:DesiredCompensationPeriod", "rdfs:label": "Annual",  "rdfs:comment": "Annual compensation expectation." },
    { "@id": "caoa:MONTHLY", "@type": "caoa:DesiredCompensationPeriod", "rdfs:label": "Monthly", "rdfs:comment": "Monthly compensation expectation." },
    { "@id": "caoa:DAILY",   "@type": "caoa:DesiredCompensationPeriod", "rdfs:label": "Daily",   "rdfs:comment": "Daily rate expectation." },
    { "@id": "caoa:HOURLY",  "@type": "caoa:DesiredCompensationPeriod", "rdfs:label": "Hourly",  "rdfs:comment": "Hourly rate expectation." }
  ]
}
