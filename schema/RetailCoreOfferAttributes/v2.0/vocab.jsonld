{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RetailCoreOfferAttributes": "beckn:RetailCoreOfferAttributes",
    "@type": "beckn:@type",
    "allowed": "beckn:allowed",
    "cancellation": "beckn:cancellation",
    "codAvailable": "beckn:codAvailable",
    "conditions": "beckn:conditions",
    "cutoffEvent": "beckn:cutoffEvent",
    "daysOfWeek": "beckn:daysOfWeek",
    "distanceConstraint": "beckn:distanceConstraint",
    "end": "beckn:end",
    "fee": "beckn:fee",
    "holidays": "beckn:holidays",
    "maxDistance": "beckn:maxDistance",
    "method": "beckn:method",
    "paymentConstraints": "beckn:paymentConstraints",
    "policies": "beckn:policies",
    "replacement": "beckn:replacement",
    "restockingFee": "beckn:restockingFee",
    "returns": "beckn:returns",
    "serviceability": "beckn:serviceability",
    "start": "beckn:start",
    "subjectToAvailability": "beckn:subjectToAvailability",
    "timeRange": "beckn:timeRange",
    "timing": "beckn:timing",
    "type": "beckn:type",
    "unit": "beckn:unit",
    "value": "beckn:value",
    "window": "beckn:window"
  },
  "@graph": [
    {
      "@id": "beckn:RetailCoreOfferAttributes",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Core Offer Attributes",
      "rdfs:comment": "Retail-specific offer attribute pack defining constraints and eligibility conditions for offers, coupons, and promotions."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "JSON-LD context URI."
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "JSON-LD type identifier."
    },
    {
      "@id": "beckn:policies",
      "@type": "rdf:Property",
      "rdfs:label": "policies",
      "rdfs:comment": "Coupon-level policies such as single-use, stacking, and minimum order value."
    },
    {
      "@id": "beckn:paymentConstraints",
      "@type": "rdf:Property",
      "rdfs:label": "payment Constraints",
      "rdfs:comment": "Eligible payment methods and instruments for this offer."
    },
    {
      "@id": "beckn:serviceability",
      "@type": "rdf:Property",
      "rdfs:label": "serviceability",
      "rdfs:comment": "Geographic or delivery-mode serviceability constraints for the offer."
    },
    {
      "@id": "beckn:timeRange",
      "@type": "rdf:Property",
      "rdfs:label": "time Range",
      "rdfs:comment": "Validity window for the offer."
    },
    {
      "@id": "beckn:holidays",
      "@type": "rdf:Property",
      "rdfs:label": "holidays",
      "rdfs:comment": "Dates on which the offer is not valid."
    }
  ]
}
