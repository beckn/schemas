                "beckn:Catalog",
                "beckn:Item",
                "beckn:Offer",
                "beckn:Provider",
                "beckn:Order",
                "beckn:Fulfillment",
                "beckn:Payment",
                "beckn:Buyer",
                "beckn:Descriptor",
                "beckn:Location",
                "beckn:Invoice",
                "beckn:Rating",
                "beckn:SupportInfo",
                "beckn:Tracking"
