        {
            "@id": "beckn:updatedAt",
            "@type": "rdf:Property",
            "rdfs:label": "Updated at",
            "rdfs:comment": "Last update timestamp (UTC).",
            "rdfs:domain": [
                "beckn:Order",
                "beckn:Invoice",
                "beckn:Offer"
            ],
            "schema:rangeIncludes": "schema:DateTime"
