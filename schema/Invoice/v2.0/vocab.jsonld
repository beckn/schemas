                "@id": "beckn:descriptor"
            }
        },
        {
            "@id": "beckn:fulfillmentDescriptor",
            "rdfs:label": "Fulfillment descriptor",
            "rdfs:comment": "Scoped descriptor for Fulfillment metadata.",
            "@type": "rdf:Property",
            "rdfs:domain": "beckn:Fulfillment",
            "schema:rangeIncludes": "beckn:FulfillmentDescriptor",
