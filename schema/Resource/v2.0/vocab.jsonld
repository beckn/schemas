{
  "@context": {
    "beckn": "https://schema.beckn.io/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@graph": [
    {
      "@id": "beckn:Resource",
      "@type": "rdfs:Class",
      "rdfs:label": "Resource",
      "rdfs:comment": "A minimal, domain-neutral abstraction representing any discoverable,\nreferenceable, or committable unit of value, capability, service,\nentitlement, or asset within the network.\n\nExamples:\n- A retail product SKU, a mobility ride, a job role, a carbon credit unit,\n a dataset/API entitlement, a training course, a clinic service slot.\n\nDesigned for composability through `resourceAttributes` where\ndomain packs can plug in their specific fields without changing the core.\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Globally unique identifier of the resource."
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": "descriptor",
      "rdfs:comment": "Property descriptor"
    },
    {
      "@id": "beckn:resourceAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "resourceAttributes",
      "rdfs:comment": "All the properties of a resource that describe its value, its terms of usage, fulfillment, and consideration"
    }
  ]
}
