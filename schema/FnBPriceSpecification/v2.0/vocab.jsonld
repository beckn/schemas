{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "FnBPriceSpecification": "beckn:FnBPriceSpecification",
    "@type": "beckn:@type",
    "components": "beckn:components",
    "currency": "beckn:currency",
    "description": "beckn:description",
    "quantity": "beckn:quantity",
    "referenceItemId": "beckn:referenceItemId",
    "type": "beckn:type",
    "value": "beckn:value"
  },
  "@graph": [
    {
      "@id": "beckn:FnBPriceSpecification",
      "@type": "rdfs:Class",
      "rdfs:label": "FnBPriceSpecification",
      "rdfs:comment": "A price specification for food and beverage delivery orders. Specializes beckn:PriceSpecification with F&B-specific component type codes covering item charges, size/crust upcharges, topping charges (size-dependent), combo savings, delivery/packaging/platform fees, and gratuity.",
      "rdfs:subClassOf": {
        "@id": "beckn:PriceSpecification"
      },
      "owl:equivalentClass": {
        "@id": "schema:PriceSpecification"
      }
    },
    {
      "@id": "schema:priceCurrency",
      "@type": "rdf:Property",
      "rdfs:label": "currency",
      "rdfs:comment": "ISO 4217 currency code for the order. Re-uses schema:priceCurrency.",
      "rdfs:domain": {
        "@id": "beckn:FnBPriceSpecification"
      }
    },
    {
      "@id": "schema:price",
      "@type": "rdf:Property",
      "rdfs:label": "value",
      "rdfs:comment": "Total order amount inclusive of all charges and discounts. Re-uses schema:price.",
      "rdfs:domain": {
        "@id": "beckn:FnBPriceSpecification"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      }
    },
    {
      "@id": "beckn:components",
      "@type": "rdf:Property",
      "rdfs:label": "components",
      "rdfs:comment": "Itemised price components of the F&B order. Component type codes: BASE_ITEM, SIZE_UPCHARGE, TOPPING, ADDON, CUSTOMIZATION, SIDE, COMBO_SAVINGS, COMBO_UPCHARGE, OFFER_DISCOUNT, COUPON_DISCOUNT, LOYALTY_DISCOUNT, DELIVERY_FEE, PACKAGING_FEE, SMALL_ORDER_FEE, PLATFORM_FEE, TIP.",
      "rdfs:domain": {
        "@id": "beckn:FnBPriceSpecification"
      }
    }
  ]
}
