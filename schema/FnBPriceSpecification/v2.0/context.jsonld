{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "FnBPriceSpecification": {
      "@id": "beckn:FnBPriceSpecification",
      "@type": "rdfs:Class",
      "rdfs:subClassOf": { "@id": "beckn:PriceSpecification" },
      "owl:equivalentClass": { "@id": "schema:PriceSpecification" }
    },
    "currency": {
      "@id": "schema:priceCurrency"
    },
    "value": {
      "@id": "schema:price",
      "@type": "xsd:decimal"
    },
    "components": {
      "@id": "beckn:components",
      "@container": "@list"
    }
  }
}
