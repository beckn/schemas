{
  "schema": "HiringJobOfferAttributes",
  "version": "1.0.0",
  "card_template": "{{hjoa:compensationMin}}–{{hjoa:compensationMax}} {{hjoa:compensationCurrency}}/{{hjoa:compensationPeriod}} | {{hjoa:openingsCount}} opening(s) | Apply by {{hjoa:applicationDeadline}}",
  "detail_template": "Compensation: {{hjoa:compensationMin}}–{{hjoa:compensationMax}} {{hjoa:compensationCurrency}} per {{hjoa:compensationPeriod}}\nOpenings: {{hjoa:openingsCount}}\nApply by: {{hjoa:applicationDeadline}}\nProbation: {{hjoa:probationPeriodMonths}} months",

  "html": "<div class=\"hiring-jobs-offer-card\"><div class=\"offer-comp\"><span class=\"comp-range\">{{beckn:offerAttributes.hjoa:compensationMin}} – {{beckn:offerAttributes.hjoa:compensationMax}}</span><span class=\"comp-currency\">{{beckn:offerAttributes.hjoa:compensationCurrency}}</span><span class=\"comp-period\">/ {{beckn:offerAttributes.hjoa:compensationPeriod}}</span></div><div class=\"offer-meta\"><span class=\"openings-badge\">{{beckn:offerAttributes.hjoa:openingsCount}} opening(s)</span>{{#if beckn:offerAttributes.hjoa:applicationDeadline}}<span class=\"deadline\">Apply by {{beckn:offerAttributes.hjoa:applicationDeadline}}</span>{{/if}}</div></div>",

  "html_detail": "<div class=\"hiring-jobs-offer-detail\"><div class=\"detail-section\"><h4>Compensation</h4><div class=\"detail-grid\"><div class=\"detail-item\"><label>Range</label><span>{{beckn:offerAttributes.hjoa:compensationMin}} – {{beckn:offerAttributes.hjoa:compensationMax}} {{beckn:offerAttributes.hjoa:compensationCurrency}}</span></div><div class=\"detail-item\"><label>Period</label><span class=\"badge\">{{beckn:offerAttributes.hjoa:compensationPeriod}}</span></div>{{#if beckn:offerAttributes.hjoa:probationPeriodMonths}}<div class=\"detail-item\"><label>Probation</label><span>{{beckn:offerAttributes.hjoa:probationPeriodMonths}} month(s)</span></div>{{/if}}</div></div><div class=\"detail-section\"><h4>Availability</h4><div class=\"detail-grid\"><div class=\"detail-item\"><label>Openings</label><span>{{beckn:offerAttributes.hjoa:openingsCount}}</span></div><div class=\"detail-item\"><label>Apply By</label><span>{{beckn:offerAttributes.hjoa:applicationDeadline}}</span></div></div></div></div>"
}
