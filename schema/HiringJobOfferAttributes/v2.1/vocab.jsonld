{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/vocab.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "hjoa": "https://schema.beckn.io/HiringJobOfferAttributes#",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "HiringJobOfferAttributes": "beckn:HiringJobOfferAttributes",
    "application_deadline": "beckn:application_deadline",
    "compensation_currency": "beckn:compensation_currency",
    "compensation_max": "beckn:compensation_max",
    "compensation_min": "beckn:compensation_min",
    "compensation_period": "beckn:compensation_period",
    "end": "beckn:end",
    "openings_count": "beckn:openings_count",
    "posting_validity": "beckn:posting_validity",
    "probation_period_months": "beckn:probation_period_months",
    "start": "beckn:start"
  },
  "@graph": [
    {
      "@id": "hjoa:CompensationPeriod",
      "@type": "rdfs:Class",
      "rdfs:label": "Compensation Period",
      "rdfs:comment": "The time unit against which compensation is measured in a job offer."
    },
    {
      "@id": "hjoa:ANNUAL",
      "@type": "hjoa:CompensationPeriod",
      "rdfs:label": "Annual",
      "rdfs:comment": "Compensation stated as an annual figure."
    },
    {
      "@id": "hjoa:MONTHLY",
      "@type": "hjoa:CompensationPeriod",
      "rdfs:label": "Monthly",
      "rdfs:comment": "Compensation stated as a monthly figure."
    },
    {
      "@id": "hjoa:DAILY",
      "@type": "hjoa:CompensationPeriod",
      "rdfs:label": "Daily",
      "rdfs:comment": "Compensation stated as a daily rate."
    },
    {
      "@id": "hjoa:HOURLY",
      "@type": "hjoa:CompensationPeriod",
      "rdfs:label": "Hourly",
      "rdfs:comment": "Compensation stated as an hourly rate."
    },
    {
      "@id": "hjoa:GIG_UNIT",
      "@type": "hjoa:CompensationPeriod",
      "rdfs:label": "Gig Unit",
      "rdfs:comment": "Compensation stated per task, delivery, or gig unit completed."
    }
  ]
}
