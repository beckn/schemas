{
  "type": "object",
  "required": [
    "status",
    "resources",
    "offer"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "object",
      "properties": {
        "descriptor": {
          "allOf": [
            {
              "$ref": "https://schema.beckn.io/Descriptor/attributes.yaml"
            },
            {
              "properties": {
                "code": {
                  "enum": [
                    "DRAFT",
                    "ACTIVE",
                    "CLOSED"
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "required": [
          "id",
          "quantity"
        ],
        "$ref": "https://schema.beckn.io/Resource/attributes.yaml"
      }
    },
    "offer": {
      "required": [
        "id",
        "resourceIds"
      ],
      "$ref": "https://schema.beckn.io/Offer/attributes.yaml"
    },
    "commitmentAttributes": {
      "description": "Domain-specific extension attributes for this commitment.",
      "allOf": [
        {
          "$ref": "https://schema.beckn.io/Attributes/attributes.yaml"
        },
        {
          "properties": {}
        }
      ]
    }
  },
  "x-lts": true,
  "description": "This schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute.",
  "$id": "https://schema.beckn.io/Commitment/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment"
}
