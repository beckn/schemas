{
  "type": "object",
  "required": [
    "status",
    "resources",
    "offer"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "object",
      "properties": {
        "descriptor": {
          "allOf": [
            {
              "$ref": "https://schema.beckn.io/Descriptor/v2.0/schema.json#/components/schemas/Descriptor"
            },
            {
              "properties": {
                "code": {
                  "enum": [
                    "DRAFT",
                    "ACTIVE",
                    "CLOSED"
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "https://schema.beckn.io/Resource/v2.0/schema.json#/components/schemas/Resource"
      }
    },
    "offer": {
      "$ref": "https://schema.beckn.io/Offer/v2.0/schema.json#/components/schemas/Offer"
    },
    "commitmentAttributes": {
      "description": "Domain-specific extension attributes for this commitment.",
      "allOf": [
        {
          "$ref": "https://schema.beckn.io/Attributes/v2.0/schema.json#/components/schemas/Attributes"
        },
        {
          "properties": {}
        }
      ]
    }
  },
  "components": {
    "schemas": {
      "Commitment": {
        "$ref": "#"
      }
    }
  }
}
