            "rdfs:comment": "A extensible set of attributes that describe the fulfillment preferences"
        },
        {
            "@id": "beckn:providerAttributes",
            "@type": "rdf:Property",
            "rdfs:label": "Provider attributes",
            "rdfs:comment": "Attribute pack for provider-level metadata.",
            "rdfs:domain": "beckn:Provider",
            "schema:rangeIncludes": "beckn:Attributes"
        },
        {
            "@id": "beckn:settlementTermAttributes",
            "rdfs:label": "settlement Term Attributes",
            "rdfs:domain": [
                "beckn:SettlementTerm"
            ],
            "schema:rangeIncludes": "beckn:Attributes",
