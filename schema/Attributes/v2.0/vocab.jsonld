            "rdfs:comment": "Additional use case specific settlement terms that must be adhered to"
        },
        {
            "@id": "beckn:supportTicketAttributes",
            "rdfs:label": "support Ticket Attributes",
            "rdfs:domain": [
                "beckn:SupportTicket"
            ],
