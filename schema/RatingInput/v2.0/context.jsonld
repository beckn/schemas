{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "RatingInput": {
            "@id": "beckn:RatingInput",
            "@context": {
                "category": {
                    "@id": "beckn:ratingCategory",
                    "@type": "@id",
                    "@context": {
                        "ORDER": "beckn:OrderRating",
                        "FULFILLMENT": "beckn:FulfillmentRating",
                        "ITEM": "beckn:ItemRating",
                        "PROVIDER": "beckn:ProviderRating",
                        "AGENT": "beckn:AgentRating",
                        "SUPPORT": "beckn:SupportRating",
                        "OTHER": "beckn:OtherRating"
                    }
                }
            }
        },
        "bestRating": "beckn:bestRating",
        "feedback": "beckn:feedback",
        "ratingValue": "beckn:ratingValue",
        "worstRating": "beckn:worstRating"
    }
}