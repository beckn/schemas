{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "MediaInput": {
            "@id": "beckn:MediaInput",
            "@context": {
                "type": {
                    "@id": "beckn:type",
                    "@context": {
                        "image": "beckn:ImageSearchInput",
                        "audio": "beckn:AudioSearchInput",
                        "video": "beckn:VideoSearchInput"
                    }
                }
            }
        },
        "contentType": "beckn:contentType",
        "endMs": "beckn:endMs",
        "language": "beckn:language",
        "media": "beckn:media",
        "startMs": "beckn:startMs",
        "textHint": "beckn:textHint",
        "type": {
            "@id": "beckn:type",
            "@type": "@id",
            "@context": {
                "Point": "beckn:GeoJSONPoint",
                "LineString": "beckn:GeoJSONLineString",
                "Polygon": "beckn:GeoJSONPolygon",
                "MultiPoint": "beckn:GeoJSONMultiPoint",
                "MultiLineString": "beckn:GeoJSONMultiLineString",
                "MultiPolygon": "beckn:GeoJSONMultiPolygon",
                "GeometryCollection": "beckn:GeoJSONGeometryCollection",
                "DELIVERY": "beckn:DeliveryPriceComponent",
                "DISCOUNT": "beckn:DiscountPriceComponent",
                "FEE": "beckn:FeePriceComponent",
                "SURCHARGE": "beckn:SurchargePriceComponent",
                "TAX": "beckn:TaxPriceComponent",
                "UNIT": "beckn:UnitPriceComponent",
                "jsonpath": "beckn:JsonPathType"
            }
        },
        "url": "beckn:url"
    }
}