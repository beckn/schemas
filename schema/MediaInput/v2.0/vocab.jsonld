{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:AudioSearchInput",
            "rdfs:label": "audio Search Input",
            "@type": "schema:Enumeration",
            "rdfs:comment": "Media category."
        },
        {
            "@id": "beckn:ImageSearchInput",
            "rdfs:label": "image Search Input",
            "@type": "schema:Enumeration",
            "rdfs:comment": "Media category."
        },
        {
            "@id": "beckn:MediaInput",
            "rdfs:label": "Media Input",
            "@type": "rdfs:Class",
            "rdfs:comment": "Reference to an image, audio clip, or video used for multimodal search."
        },
        {
            "@id": "beckn:VideoSearchInput",
            "rdfs:label": "video Search Input",
            "@type": "schema:Enumeration",
            "rdfs:comment": "Media category."
        },
        {
            "@id": "beckn:contentType",
            "rdfs:label": "content Type",
            "rdfs:domain": [
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "MIME type, e.g., image/jpeg, audio/mpeg, video/mp4."
        },
        {
            "@id": "beckn:endMs",
            "rdfs:label": "end Ms",
            "rdfs:domain": [
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Integer",
            "@type": "rdf:Property",
            "rdfs:comment": "Optional end offset in milliseconds (for audio/video segments)."
        },
        {
            "@id": "beckn:language",
            "rdfs:label": "language",
            "rdfs:domain": [
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Language code (BCP-47) of `textHint` or spoken audio."
        },
        {
            "@id": "beckn:media",
            "rdfs:label": "media",
            "rdfs:domain": [
                "beckn:MediaSearch"
            ],
            "schema:rangeIncludes": "beckn:MediaInput",
            "@type": "rdf:Property",
            "rdfs:comment": "One or more references to **images, audio notes, or videos** supplied as part of a multimodal search. Each entry references a media resource accessible via HTTPS or data URI."
        },
        {
            "@id": "beckn:startMs",
            "rdfs:label": "start Ms",
            "rdfs:domain": [
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Integer",
            "@type": "rdf:Property",
            "rdfs:comment": "Optional start offset in milliseconds (for audio/video segments)."
        },
        {
            "@id": "beckn:textHint",
            "rdfs:label": "text Hint",
            "rdfs:domain": [
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Optional pre-extracted text (OCR/ASR) for search augmentation."
        },
        {
            "@id": "beckn:type",
            "rdfs:label": "type",
            "rdfs:domain": [
                "beckn:GeoJSONGeometry",
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Media category."
        },
        {
            "@id": "beckn:url",
            "rdfs:label": "url",
            "rdfs:domain": [
                "beckn:Document",
                "beckn:Form",
                "beckn:MediaInput",
                "beckn:SupportInfo",
                "beckn:TrackAction",
                "beckn:Tracking"
            ],
            "schema:rangeIncludes": "schema:URL",
            "@type": "rdf:Property",
            "rdfs:comment": "URL to the document"
        }
    ]
}