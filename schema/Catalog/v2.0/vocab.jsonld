{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Catalog",
      "@type": "rdfs:Class",
      "rdfs:label": "Catalog",
      "rdfs:comment": "Catalog schema for Beckn Protocol v2.0.1"
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "JSON-LD context URI for the core Catalog schema"
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "Type of the catalog"
    },
    {
      "@id": "beckn:bppId",
      "@type": "rdf:Property",
      "rdfs:label": "bpp Id",
      "rdfs:comment": "BPP (Beckn Protocol Provider) identifier that publishes this catalog"
    },
    {
      "@id": "beckn:bppUri",
      "@type": "rdf:Property",
      "rdfs:label": "bpp Uri",
      "rdfs:comment": "BPP (Beckn Protocol Provider) URI endpoint"
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": "descriptor",
      "rdfs:comment": "A verbal summary of the catalog for humans, AI agents, etc to read and understand the context."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for the catalog"
    },
    {
      "@id": "beckn:isActive",
      "@type": "rdf:Property",
      "rdfs:label": "is Active",
      "rdfs:comment": "Whether the catalog is active"
    },
    {
      "@id": "beckn:items",
      "@type": "rdf:Property",
      "rdfs:label": "items",
      "rdfs:comment": "Array of beckn core Item entities in this catalog"
    },
    {
      "@id": "beckn:offers",
      "@type": "rdf:Property",
      "rdfs:label": "offers",
      "rdfs:comment": "TODO: Description Needed - offers"
    },
    {
      "@id": "beckn:providerId",
      "@type": "rdf:Property",
      "rdfs:label": "provider Id",
      "rdfs:comment": "Reference to the provider that owns this catalog"
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": "validity",
      "rdfs:comment": "The time period during which this catalog is valid"
    }
  ]
}
