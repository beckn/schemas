{
  "type": "object",
  "description": "Schema definition for Provider in the Beckn Protocol v2.0.1",
  "title": "Provider",
  "properties": {
    "id": {
      "description": "Unique identifier for the provider",
      "type": "string",
      "example": "tech-store-001"
    },
    "descriptor": {
      "$ref": "https://schema.beckn.io/Descriptor/v2.1/schema.json#/components/schemas/Descriptor"
    },
    "availableAt": {
      "description": "Physical locations where the provider operates",
      "type": "array",
      "items": {
        "$ref": "https://schema.beckn.io/Location/v2.0/schema.json#/components/schemas/Location"
      }
    },
    "providerAttributes": {
      "$ref": "https://schema.beckn.io/Attributes/v2.0/schema.json#/components/schemas/Attributes"
    }
  },
  "required": [
    "id",
    "descriptor"
  ],
  "additionalProperties": false,
  "components": {
    "schemas": {
      "Provider": {
        "$ref": "#"
      }
    }
  }
}
