{
  "$id": "https://schema.beckn.io/Provider/v2.1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Schema definition for Provider in the Beckn Protocol v2.0.1",
  "title": "Provider",
  "properties": {
    "id": {
      "description": "Unique identifier for the provider",
      "type": "string",
      "example": "tech-store-001"
    },
    "descriptor": {
      "$ref": "https://schema.beckn.io/Descriptor/v2.1/schema.json"
    },
    "availableAt": {
      "description": "Physical locations where the provider operates",
      "type": "array",
      "items": {
        "$ref": "https://schema.beckn.io/Location/v2.0/schema.json"
      }
    },
    "providerAttributes": {
      "$ref": "https://schema.beckn.io/Attributes/v2.0/schema.json"
    }
  },
  "required": [
    "id",
    "descriptor"
  ],
  "additionalProperties": false
}
