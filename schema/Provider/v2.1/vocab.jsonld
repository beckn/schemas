{
  "@context": {
    "beckn": "https://schema.beckn.io/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@graph": [
    {
      "@id": "beckn:Provider",
      "@type": "rdfs:Class",
      "rdfs:label": "Provider",
      "rdfs:comment": "Schema definition for Provider in the Beckn Protocol v2.0.1\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for the provider"
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": "descriptor",
      "rdfs:comment": "Property descriptor"
    },
    {
      "@id": "beckn:availableAt",
      "@type": "rdf:Property",
      "rdfs:label": "availableAt",
      "rdfs:comment": "Physical locations where the provider operates"
    },
    {
      "@id": "beckn:providerAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "providerAttributes",
      "rdfs:comment": "Property providerAttributes"
    }
  ]
}
