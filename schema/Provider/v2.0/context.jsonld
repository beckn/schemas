{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "Provider": {
            "@id": "beckn:Provider",
            "@context": {
                "descriptor": "beckn:providerDescriptor"
            }
        },
        "descriptor": "beckn:descriptor",
        "id": "beckn:id",
        "location": "beckn:location",
        "locations": "beckn:locations",
        "payee": "beckn:payee",
        "provider": "beckn:Provider",
        "providerAttributes": "beckn:providerAttributes",
        "rateable": "beckn:rateable",
        "rating": "beckn:rating",
        "supportInfo": "beckn:supportInfo",
        "validity": "beckn:validity",
        "policies": "beckn:policies",
        "alerts": "beckn:alerts"
    }
}
