{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:GeoJSONGeometry",
            "@type": "rdfs:Class",
            "rdfs:label": "GeoJSON Geometry",
            "rdfs:comment": "A GeoJSON geometry object (Point, LineString, Polygon, etc.)."
        },
        {
            "@id": "beckn:bbox",
            "rdfs:label": "bbox",
            "rdfs:domain": [
                "beckn:GeoJSONGeometry"
            ],
            "@type": "rdf:Property",
            "rdfs:comment": "Optional bounding box `[west, south, east, north]` in degrees."
        },
        {
            "@id": "beckn:coordinates",
            "rdfs:label": "coordinates",
            "rdfs:domain": [
                "beckn:GeoJSONGeometry"
            ],
            "@type": "rdf:Property",
            "rdfs:comment": "Coordinates per RFC 7946 for all types **except** GeometryCollection. Order is **[lon, lat, (alt)]**. For Polygons, this is an array of linear rings; each ring is an array of positions."
        },
        {
            "@id": "beckn:geo",
            "@type": "rdf:Property",
            "rdfs:label": "Geo",
            "rdfs:comment": "GeoJSON geometry for the location.",
            "rdfs:domain": "beckn:Location",
            "schema:rangeIncludes": "beckn:GeoJSONGeometry"
        },
        {
            "@id": "beckn:geometries",
            "rdfs:label": "geometries",
            "rdfs:domain": [
                "beckn:GeoJSONGeometry"
            ],
            "schema:rangeIncludes": "beckn:GeoJSONGeometry",
            "@type": "rdf:Property",
            "rdfs:comment": "Member geometries when `type` is **GeometryCollection**."
        },
        {
            "@id": "beckn:geometry",
            "rdfs:label": "geometry",
            "rdfs:domain": [
                "beckn:SpatialConstraint"
            ],
            "schema:rangeIncludes": "beckn:GeoJSONGeometry",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:type",
            "rdfs:label": "type",
            "rdfs:domain": [
                "beckn:GeoJSONGeometry",
                "beckn:MediaInput"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Media category."
        }
    ]
}