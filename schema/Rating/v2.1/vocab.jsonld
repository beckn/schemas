{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Rating",
      "@type": "rdfs:Class",
      "rdfs:label": "Rating",
      "rdfs:comment": "Aggregated rating information for an entity. Aligns with schema.org/AggregateRating semantics."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "TODO: Description Needed - @context"
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "TODO: Description Needed - @type"
    },
    {
      "@id": "beckn:ratingValue",
      "@type": "rdf:Property",
      "rdfs:label": "rating Value",
      "rdfs:comment": "Rating value (typically 0-5)"
    },
    {
      "@id": "beckn:ratingCount",
      "@type": "rdf:Property",
      "rdfs:label": "rating Count",
      "rdfs:comment": "Number of ratings"
    },
    {
      "@id": "beckn:reviewText",
      "@type": "rdf:Property",
      "rdfs:label": "review Text",
      "rdfs:comment": "Optional textual review or comment"
    }
  ]
}
