        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "Location": {
            "@id": "beckn:Location",
            "@context": {
                "descriptor": "beckn:locationDescriptor"
            }
        },
        "address": "beckn:address",
        "geo": "beckn:geo",
        "id": "beckn:id",
        "location": "beckn:Location",
        "instructions": "beckn:instructions"
    }
}
