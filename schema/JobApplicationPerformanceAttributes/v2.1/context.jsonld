{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "japa": "https://schema.beckn.io/JobApplicationPerformanceAttributes#",
    "cr": "https://schema.beckn.io/CredentialRequirement#",
    "japa:verificationMethod": {
      "@id": "japa:verificationMethod"
    },
    "japa:perRequirementResults": {
      "@id": "japa:perRequirementResults",
      "@container": "@list"
    },
    "japa:requirementResult": {
      "@id": "japa:requirementResult"
    },
    "japa:proofHash": {
      "@id": "japa:proofHash"
    },
    "japa:issuerDidsVerified": {
      "@id": "japa:issuerDidsVerified",
      "@container": "@list"
    },
    "japa:routedToProvider": {
      "@id": "japa:routedToProvider"
    },
    "japa:routingTimestamp": {
      "@id": "schema:dateModified"
    },
    "cr:category": {
      "@id": "cr:category"
    },
    "cr:subtype": {
      "@id": "cr:subtype"
    },
    "cr:mandatory": {
      "@id": "cr:mandatory"
    },
    "verification_method": "beckn:verification_method",
    "per_requirement_results": "beckn:per_requirement_results",
    "proof_hash": "beckn:proof_hash",
    "issuer_dids_verified": "beckn:issuer_dids_verified",
    "routed_to_provider": "beckn:routed_to_provider",
    "routing_timestamp": "beckn:routing_timestamp",
    "RequirementResult": "japa:RequirementResult",
    "VerificationMethod": "japa:VerificationMethod",
    "JobApplicationPerformanceAttributes": "beckn:JobApplicationPerformanceAttributes",
    "category": "beckn:category",
    "mandatory": "beckn:mandatory",
    "result": "beckn:result",
    "subtype": "beckn:subtype"
  }
}
