{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "RetailCoreOrderAttributes": "beckn:RetailCoreOrderAttributes",
    "@type": "beckn:@type",
    "buyerInstructions": "beckn:buyerInstructions",
    "campaignId": "beckn:campaignId",
    "channel": "beckn:channel",
    "companyName": "beckn:companyName",
    "contactless": "beckn:contactless",
    "country": "beckn:country",
    "deliveryPreferences": "beckn:deliveryPreferences",
    "email": "beckn:email",
    "end": "beckn:end",
    "gift": "beckn:gift",
    "invoicePreferences": "beckn:invoicePreferences",
    "isGift": "beckn:isGift",
    "leaveAtDoor": "beckn:leaveAtDoor",
    "loyalty": "beckn:loyalty",
    "message": "beckn:message",
    "pointsRedeemed": "beckn:pointsRedeemed",
    "preferredTimeSlot": "beckn:preferredTimeSlot",
    "programId": "beckn:programId",
    "scheme": "beckn:scheme",
    "source": "beckn:source",
    "start": "beckn:start",
    "taxId": "beckn:taxId",
    "value": "beckn:value",
    "wrap": "beckn:wrap"
  },
  "@graph": [
    {
      "@id": "beckn:RetailCoreOrderAttributes",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Core Order Attributes",
      "rdfs:comment": "Retail-specific order attribute pack capturing buyer preferences and supplementary information at the order level."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "JSON-LD context URI."
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "JSON-LD type identifier."
    },
    {
      "@id": "beckn:buyerInstructions",
      "@type": "rdf:Property",
      "rdfs:label": "buyer Instructions",
      "rdfs:comment": "Free-text instructions from the buyer to the seller."
    },
    {
      "@id": "beckn:deliveryPreferences",
      "@type": "rdf:Property",
      "rdfs:label": "delivery Preferences",
      "rdfs:comment": "Preferences relating to delivery time, instructions, or contactless options."
    },
    {
      "@id": "beckn:gift",
      "@type": "rdf:Property",
      "rdfs:label": "gift",
      "rdfs:comment": "Gifting metadata such as message and wrapping preference."
    },
    {
      "@id": "beckn:invoicePreferences",
      "@type": "rdf:Property",
      "rdfs:label": "invoice Preferences",
      "rdfs:comment": "Invoicing preferences including GST number or billing address."
    },
    {
      "@id": "beckn:loyalty",
      "@type": "rdf:Property",
      "rdfs:label": "loyalty",
      "rdfs:comment": "Loyalty programme details for earning or redeeming points."
    },
    {
      "@id": "beckn:source",
      "@type": "rdf:Property",
      "rdfs:label": "source",
      "rdfs:comment": "Order source attribution details."
    }
  ]
}
