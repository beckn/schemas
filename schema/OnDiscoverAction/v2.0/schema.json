{
  "$id": "https://schema.beckn.io/OnDiscoverAction/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OnDiscoverAction",
  "description": "Beckn /beckn/on_discover message payload. Sent by a BPP or CDS to a BAP\nin response to a discover request. Contains matching catalogs.\n",
  "x-tags": [
    "common"
  ],
  "type": "object",
  "properties": {
    "context": {
      "allOf": [
        {
          "$ref": "https://schema.beckn.io/Context/attributes.yaml"
        },
        {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "beckn/on_discover"
            }
          }
        }
      ]
    },
    "message": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "catalogs"
      ],
      "properties": {
        "catalogs": {
          "type": "array",
          "description": "Array of catalogs matching the discovery request.\nEach catalog contains items and/or resources available from a provider.\n",
          "items": {
            "$ref": "https://schema.beckn.io/Catalog/attributes.yaml"
          }
        }
      }
    }
  },
  "required": [
    "context",
    "message"
  ]
}
