{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "hppa": "https://schema.beckn.io/HiringProcessPerformanceAttributes#",
    "vs": "https://schema.beckn.io/VerificationSummary#",
    "hppa:stage": {
      "@id": "hppa:stage"
    },
    "hppa:interviewSchedule": {
      "@id": "hppa:interviewSchedule",
      "@container": "@list"
    },
    "hppa:interviewFormat": {
      "@id": "hppa:interviewFormat"
    },
    "hppa:interviewTopic": {
      "@id": "hppa:interviewTopic"
    },
    "hppa:assessmentRequired": {
      "@id": "hppa:assessmentRequired"
    },
    "hppa:assessmentReference": {
      "@id": "hppa:assessmentReference"
    },
    "hppa:verificationRequested": {
      "@id": "hppa:verificationRequested"
    },
    "hppa:verificationSummary": {
      "@id": "hppa:verificationSummary"
    },
    "schema:startDate": {
      "@id": "schema:startDate"
    },
    "vs:overallResult": {
      "@id": "vs:overallResult"
    },
    "vs:reasonCodes": {
      "@id": "vs:reasonCodes",
      "@container": "@list"
    },
    "vs:verifiedCategories": {
      "@id": "vs:verifiedCategories",
      "@container": "@list"
    },
    "vs:verifiedSubtypes": {
      "@id": "vs:verifiedSubtypes",
      "@container": "@list"
    },
    "vs:checkedAt": {
      "@id": "vs:checkedAt"
    },
    "vs:proofMetadataHash": {
      "@id": "vs:proofMetadataHash"
    },
    "stage": "beckn:stage",
    "interview_schedule": "beckn:interview_schedule",
    "assessment_required": "beckn:assessment_required",
    "assessment_reference": "beckn:assessment_reference",
    "verification_requested": "beckn:verification_requested",
    "verification_summary": "beckn:verification_summary",
    "HiringStage": "hppa:HiringStage",
    "InterviewFormat": "hppa:InterviewFormat",
    "HiringProcessPerformanceAttributes": "beckn:HiringProcessPerformanceAttributes",
    "format": "beckn:format",
    "session_date": "beckn:session_date",
    "topic": "beckn:topic"
  }
}
