{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:BecknAction",
      "@type": "rdfs:Class",
      "rdfs:label": "Beckn Action",
      "rdfs:comment": "Unified Beckn action envelope. All Beckn API requests and callbacks conform to this schema. The context identifies the action being performed; the message carries the action-specific payload. Message content is validated via if/then dispatch based on context.action. For unknown or extension endpoints, no if/then branch applies and message remains unconstrained. This schema supersedes RequestAction and CallbackAction, both of which were structurally invalid. The request/callback distinction is encoded in the context.action value (e.g. beckn/discover vs beckn/on_discover), not in a separate schema type."
    },
    {
      "@id": "beckn:context",
      "@type": "rdf:Property",
      "rdfs:label": "context",
      "rdfs:comment": "Transaction context identifying the action, sender, receiver, and correlation IDs."
    },
    {
      "@id": "beckn:message",
      "@type": "rdf:Property",
      "rdfs:label": "message",
      "rdfs:comment": "Action-specific payload. Content constraints applied via if/then dispatch below."
    }
  ]
}
