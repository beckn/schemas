{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:MediaSearch",
            "rdfs:label": "Media Search",
            "@type": "rdfs:Class",
            "rdfs:comment": "Container for multimodal search inputs and configuration. Supports searching through **images, audio notes, and videos** alongside text, filters, and spatial predicates. For GET, this object should be JSON-encoded and URL-escaped."
        },
        {
            "@id": "beckn:media",
            "rdfs:label": "media",
            "rdfs:domain": [
                "beckn:MediaSearch"
            ],
            "schema:rangeIncludes": "beckn:MediaInput",
            "@type": "rdf:Property",
            "rdfs:comment": "One or more references to **images, audio notes, or videos** supplied as part of a multimodal search. Each entry references a media resource accessible via HTTPS or data URI."
        },
        {
            "@id": "beckn:mediaSearch",
            "rdfs:label": "media_search",
            "rdfs:domain": [
                "beckn:DiscoveryIntent"
            ],
            "schema:rangeIncludes": "beckn:MediaSearch",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:options",
            "rdfs:label": "options",
            "rdfs:domain": [
                "beckn:MediaSearch"
            ],
            "schema:rangeIncludes": "beckn:MediaSearchOptions",
            "@type": "rdf:Property",
            "rdfs:comment": "Options controlling how the discovery engine interprets the supplied media \u2014 e.g., whether to perform OCR/ASR, semantic similarity, or object detection."
        }
    ]
}