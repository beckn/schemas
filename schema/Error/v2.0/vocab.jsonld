{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Error",
            "@type": "rdfs:Class",
            "rdfs:label": "Error",
            "rdfs:comment": "Standard error object for reporting failures in API flows."
        },
        {
            "@id": "beckn:code",
            "rdfs:label": "code",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Error code"
        },
        {
            "@id": "beckn:details",
            "rdfs:label": "details",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Thing",
            "@type": "rdf:Property",
            "rdfs:comment": "Additional error details"
        },
        {
            "@id": "beckn:error",
            "rdfs:label": "error",
            "rdfs:domain": [
                "beckn:AckResponse",
                "beckn:CatalogProcessingResult",
                "beckn:ErrorResponse"
            ],
            "schema:rangeIncludes": "beckn:Error",
            "@type": "rdf:Property",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:errorCode",
            "@type": "rdf:Property",
            "rdfs:label": "Error code",
            "rdfs:comment": "Machine-readable error code.",
            "rdfs:domain": "beckn:Error",
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:errorDetails",
            "@type": "rdf:Property",
            "rdfs:label": "Error details",
            "rdfs:comment": "Additional error details.",
            "rdfs:domain": "beckn:Error",
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:errorMessage",
            "@type": "rdf:Property",
            "rdfs:label": "Error message",
            "rdfs:comment": "Human-readable error message.",
            "rdfs:domain": "beckn:Error",
            "schema:rangeIncludes": "schema:Text"
        },
        {
            "@id": "beckn:message",
            "rdfs:label": "message",
            "rdfs:domain": [
                "beckn:Error",
                "beckn:ProcessingNotice"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Human-readable error message"
        }
    ]
}