    "@graph": [
        {
            "@id": "beckn:Time",
            "rdfs:label": "Time",
            "@type": "rdfs:Class",
            "rdfs:comment": "Represents a moment or duration in time. Can express a timestamp, a duration, or a time range."
        },
        {
            "@id": "beckn:range",
            "rdfs:label": "range",
            "rdfs:domain": [
                "beckn:Time"
            ],
            "schema:rangeIncludes": "beckn:TimePeriod",
            "@type": "rdf:Property",
            "rdfs:comment": "A time range with start and end"
        },
        {
            "@id": "beckn:time",
            "rdfs:label": "time",
            "rdfs:domain": [
                "beckn:FulfillmentStageEndpoint"
            ],
            "schema:rangeIncludes": "beckn:Time",
            "@type": "rdf:Property",
