{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:MediaFile",
            "rdfs:label": "Media File",
            "@type": "rdfs:Class",
            "rdfs:comment": "A image, audio, or video typically intended for display purposes"
        },
        {
            "@id": "beckn:label",
            "rdfs:label": "label",
            "rdfs:domain": [
                "beckn:Document",
                "beckn:MediaFile"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "The display name of the media file"
        },
        {
            "@id": "beckn:mediaFile",
            "rdfs:label": "media File",
            "rdfs:domain": [
                "beckn:Descriptor"
            ],
            "schema:rangeIncludes": "beckn:MediaFile",
            "@type": "rdf:Property",
            "rdfs:comment": "Links to multimedia files and images"
        },
        {
            "@id": "beckn:mediaFiles",
            "rdfs:label": "media Files",
            "rdfs:domain": [
                "beckn:FulfillmentStageAuthorization"
            ],
            "schema:rangeIncludes": "beckn:MediaFile",
            "@type": "rdf:Property",
            "rdfs:comment": "Media files required to enter or exit this fulfillment stage. The could be images of delivered packages, recorded video proof of installation, etc"
        },
        {
            "@id": "beckn:uri",
            "rdfs:label": "uri",
            "rdfs:domain": [
                "beckn:MediaFile"
            ],
            "schema:rangeIncludes": "schema:URL",
            "@type": "rdf:Property",
            "rdfs:comment": "URL to the document"
        }
    ]
}