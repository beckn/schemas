{
  "type": "object",
  "description": "Generalized representation of value exchanged under a Contract.\n\nConsideration is domain-neutral and may represent:\n- Monetary value\n- Credits / tokens\n- Asset transfer\n- Service exchange\n- Compliance artifact",
  "required": [
    "id",
    "status"
  ],
  "properties": {
    "id": {
      "description": "Identifier of this consideration",
      "type": "string"
    },
    "status": {
      "$ref": "https://schema.beckn.io/Descriptor/v2.0/schema.json#/components/schemas/Descriptor"
    },
    "considerationAttributes": {
      "$ref": "https://schema.beckn.io/Attributes/v2.0/schema.json#/components/schemas/Attributes"
    }
  },
  "components": {
    "schemas": {
      "Consideration": {
        "$ref": "#"
      }
    }
  }
}
