{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "Participant": {
            "@id": "beckn:Participant",
            "@context": {
                "descriptor": "beckn:participantDescriptor"
            }
        },
        "participants": "beckn:participants",
        "skills": "beckn:skills",
        "credentials": "beckn:credentials"
    }
}