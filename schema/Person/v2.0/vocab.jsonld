{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:Person",
            "rdfs:label": "Person",
            "rdfs:comment": "Proxy for schema:Person to avoid schema.org IRIs in context.",
            "@type": "rdfs:Class",
            "owl:equivalentClass": {
                "@id": "schema:Person"
            }
        },
        {
            "@id": "beckn:personAttributes",
            "rdfs:label": "person Attributes",
            "rdfs:domain": [
                "beckn:Person"
            ],
            "schema:rangeIncludes": "beckn:Attributes",
            "@type": "rdf:Property",
            "rdfs:comment": "Extensible attribute pack for jurisdictional or domain-specific person properties"
        }
    ]
}