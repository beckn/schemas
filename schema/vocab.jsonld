      "schema:rangeIncludes": "schema:Text"
    },
    {
      "@id": "beckn:Feature",
      "@type": "rdfs:Class",
      "rdfs:label": "Feature",
      "rdfs:comment": "A generic capability/amenity/attribute of an offering or provider (e.g., accessibility, connectivity, inclusions).",
      "rdfs:subClassOf": "schema:DefinedTerm"
    },
    {
      "@id": "beckn:Policy",
      "@type": "rdfs:Class",
      "rdfs:label": "Policy",
      "rdfs:comment": "A generic policy artifact describing rules/terms applicable to providers, offerings, orders, or fulfillments.",
      "rdfs:subClassOf": "schema:CreativeWork"
    },
    {
      "@id": "beckn:Constraint",
      "@type": "rdfs:Class",
      "rdfs:label": "Constraint",
      "rdfs:comment": "A generic quantitative or logical constraint applicable to an item or offer (e.g., max duration, max distance, limits).",
      "rdfs:subClassOf": "schema:Intangible"
    },
    {
      "@id": "beckn:Participant",
      "@type": "rdfs:Class",
      "rdfs:label": "Participant",
