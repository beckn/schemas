    {
      "@id": "beckn:BecknAction",
      "@type": "rdfs:Class",
      "rdfs:label": "BecknAction",
      "rdfs:comment": "Unified Beckn action envelope. All Beckn API requests and callbacks conform to this schema. The context identifies the action being performed; the message carries the action-specific payload."
    },
    {
      "@id": "beckn:BecknEndpoint",
      "@type": "rdfs:Class",
      "rdfs:label": "BecknEndpoint",
      "rdfs:comment": "A Beckn protocol endpoint identifier. Conforms to the pattern beckn/{action}. Known endpoints include beckn/discover, beckn/on_discover, and 18 others."
    },
    {
      "@id": "beckn:Message",
      "@type": "rdfs:Class",
      "rdfs:label": "Message",
      "rdfs:comment": "An open container for action-specific payload in a Beckn action envelope. Content constraints are applied per context.action value."
    },
    {
      "@id": "beckn:LineageEntry",
      "@type": "rdfs:Class",
      "rdfs:label": "LineageEntry",
      "rdfs:comment": "A causal attribution record asserting that a Beckn transaction was triggered by an upstream Beckn interaction. Carries the upstream action, transactionId, messageId, and a BLAKE-512 digest."
    },
    {
      "@id": "beckn:FormSubmission",
      "@type": "rdfs:Class",
      "rdfs:label": "FormSubmission",
      "rdfs:comment": "A user's submitted response to a Beckn form. Captures filled-in field values keyed by form field names."
    },
    {
      "@id": "beckn:lineage",
      "@type": "rdf:Property",
      "rdfs:label": "lineage",
      "rdfs:comment": "An optional array of causal attribution records (LineageEntry) asserting that this Beckn transaction was triggered by one or more upstream Beckn interactions.",
      "rdfs:domain": {
        "@id": "beckn:Context"
      },
      "rdfs:range": {
        "@id": "beckn:LineageEntry"
      }
    },
