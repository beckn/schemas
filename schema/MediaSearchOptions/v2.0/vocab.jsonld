{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:MediaSearchOptions",
            "rdfs:label": "Media Search Options",
            "@type": "rdfs:Class",
            "rdfs:comment": "How the discovery engine should use the provided media inputs."
        },
        {
            "@id": "beckn:augmentTextSearch",
            "rdfs:label": "augment Text Search",
            "rdfs:domain": [
                "beckn:MediaSearchOptions"
            ],
            "schema:rangeIncludes": "schema:Boolean",
            "@type": "rdf:Property",
            "rdfs:comment": "Whether to append extracted text from OCR/ASR to `textSearch`."
        },
        {
            "@id": "beckn:goals",
            "rdfs:label": "goals",
            "rdfs:domain": [
                "beckn:MediaSearchOptions"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Desired processing goals for the media."
        },
        {
            "@id": "beckn:options",
            "rdfs:label": "options",
            "rdfs:domain": [
                "beckn:MediaSearch"
            ],
            "schema:rangeIncludes": "beckn:MediaSearchOptions",
            "@type": "rdf:Property",
            "rdfs:comment": "Options controlling how the discovery engine interprets the supplied media \u2014 e.g., whether to perform OCR/ASR, semantic similarity, or object detection."
        },
        {
            "@id": "beckn:restrictResultsToMediaProximity",
            "rdfs:label": "restrict Results To Media Proximity",
            "rdfs:domain": [
                "beckn:MediaSearchOptions"
            ],
            "schema:rangeIncludes": "schema:Boolean",
            "@type": "rdf:Property",
            "rdfs:comment": "Restrict results to spatial proximity of media-derived coordinates (e.g., EXIF GPS tags)."
        }
    ]
}