{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "hjra": "https://schema.beckn.io/HiringJobResourceAttributes#",
    "hjra:jobType": {
      "@id": "hjra:jobType"
    },
    "hjra:workMode": {
      "@id": "hjra:workMode"
    },
    "hjra:industryType": {
      "@id": "hjra:industryType"
    },
    "hjra:location": {
      "@id": "schema:location"
    },
    "hjra:serviceArea": {
      "@id": "schema:areaServed"
    },
    "hjra:requirements": {
      "@id": "hjra:requirements",
      "@container": "@list"
    },
    "hjra:tags": {
      "@id": "schema:keywords",
      "@container": "@list"
    },
    "schema:addressLocality": {
      "@id": "schema:addressLocality"
    },
    "schema:addressRegion": {
      "@id": "schema:addressRegion"
    },
    "schema:addressCountry": {
      "@id": "schema:addressCountry"
    },
    "job_type": "beckn:job_type",
    "work_mode": "beckn:work_mode",
    "industry_type": "beckn:industry_type",
    "location": "beckn:location",
    "service_area": "beckn:service_area",
    "requirements": "beckn:requirements",
    "tags": "beckn:tags",
    "JobType": "hjra:JobType",
    "WorkMode": "hjra:WorkMode",
    "HiringJobResourceAttributes": "beckn:HiringJobResourceAttributes",
    "city": "beckn:city",
    "country": "beckn:country",
    "region": "beckn:region"
  }
}
