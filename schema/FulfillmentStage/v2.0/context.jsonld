{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://schema.beckn.io/",
        "FulfillmentStage": "beckn:FulfillmentStage",
        "fulfillmentStageAttributes": "beckn:fulfillmentStageAttributes",
        "preferences": "beckn:preferences",
        "stages": {
            "@id": "beckn:stages",
            "@container": "@set",
            "@context": {
                "@type": "beckn:FulfillmentStage",
                "start": {
                    "@id": "beckn:stageStart"
                },
                "end": {
                    "@id": "beckn:stageEnd"
                }
            }
        }
    }
}