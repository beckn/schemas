{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:RetailCoreOfferAttributes",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Core Offer Attributes",
      "rdfs:comment": "TODO: Description Needed - RetailCoreOfferAttributes"
    },
    {
      "@id": "beckn:policies",
      "@type": "schema:Property",
      "rdfs:label": "Policies",
      "rdfs:comment": "TODO: Description Needed - policies"
    },
    {
      "@id": "beckn:returns",
      "@type": "schema:Property",
      "rdfs:label": "Returns",
      "rdfs:comment": "Return policy applicable to the offer."
    },
    {
      "@id": "beckn:cancellation",
      "@type": "schema:Property",
      "rdfs:label": "Cancellation",
      "rdfs:comment": "Cancellation policy applicable to the offer."
    },
    {
      "@id": "beckn:replacement",
      "@type": "schema:Property",
      "rdfs:label": "Replacement",
      "rdfs:comment": "Replacement policy applicable to the offer."
    },
    {
      "@id": "beckn:allowed",
      "@type": "schema:Property",
      "rdfs:label": "Allowed",
      "rdfs:comment": "TODO: Description Needed - allowed"
    },
    {
      "@id": "beckn:window",
      "@type": "schema:Property",
      "rdfs:label": "Window",
      "rdfs:comment": "Return window as ISO 8601 duration (e.g., P7D). Interpreted from order delivery unless specified otherwise by profile."
    },
    {
      "@id": "beckn:method",
      "@type": "schema:Property",
      "rdfs:label": "Method",
      "rdfs:comment": "Return handling method."
    },
    {
      "@id": "beckn:restockingFee",
      "@type": "schema:Property",
      "rdfs:label": "Restocking Fee",
      "rdfs:comment": "Optional restocking fee applicable on return."
    },
    {
      "@id": "beckn:fee",
      "@type": "schema:Property",
      "rdfs:label": "Fee",
      "rdfs:comment": "Optional cancellation fee."
    },
    {
      "@id": "beckn:cutoffEvent",
      "@type": "schema:Property",
      "rdfs:label": "Cutoff Event",
      "rdfs:comment": "Optional lifecycle cutoff for cancellation eligibility."
    },
    {
      "@id": "beckn:subjectToAvailability",
      "@type": "schema:Property",
      "rdfs:label": "Subject To Availability",
      "rdfs:comment": "Indicates whether replacement depends on stock availability."
    },
    {
      "@id": "beckn:serviceability",
      "@type": "schema:Property",
      "rdfs:label": "Serviceability",
      "rdfs:comment": "Additional serviceability constraints beyond geographic eligibility (handled via core Offer.eligibleRegion)."
    },
    {
      "@id": "beckn:distanceConstraint",
      "@type": "schema:Property",
      "rdfs:label": "Distance Constraint",
      "rdfs:comment": "Circular distance constraint from provider location."
    },
    {
      "@id": "beckn:maxDistance",
      "@type": "schema:Property",
      "rdfs:label": "Max Distance",
      "rdfs:comment": "TODO: Description Needed - maxDistance"
    },
    {
      "@id": "beckn:OperatingSchedule",
      "@type": "rdfs:Class",
      "rdfs:label": "Operating Schedule",
      "rdfs:comment": "TODO: Description Needed - OperatingSchedule"
    },
    {
      "@id": "beckn:timeRange",
      "@type": "schema:Property",
      "rdfs:label": "Time Range",
      "rdfs:comment": "Daily time window applicable on the specified days."
    }
  ]
}
