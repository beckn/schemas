{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "HyperlocalDelivery": {
      "@id": "beckn:HyperlocalDelivery",
      "@type": "rdfs:Class",
      "owl:equivalentClass": { "@id": "schema:ParcelDelivery" }
    },
    "pickupLocation": {
      "@id": "schema:originAddress",
      "@type": "@id"
    },
    "deliveryLocation": {
      "@id": "schema:deliveryAddress",
      "@type": "@id"
    },
    "itemsShipped": {
      "@id": "schema:itemShipped",
      "@container": "@list"
    },
    "agent": {
      "@id": "schema:carrier",
      "@type": "@id"
    },
    "trackingUrl": {
      "@id": "schema:trackingUrl",
      "@type": "@id"
    },
    "expectedArrivalFrom": {
      "@id": "schema:expectedArrivalFrom",
      "@type": "xsd:dateTime"
    },
    "expectedArrivalUntil": {
      "@id": "schema:expectedArrivalUntil",
      "@type": "xsd:dateTime"
    }
  }
}
