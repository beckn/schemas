{
  "@context": {
    "@version": 1.1,
    "@import": "https://schema.beckn.io/core/v2/context.jsonld",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "aafa": "https://schema.beckn.io/AgriAdvisoryFulfillmentAttributes#",
    "AgriAdvisoryFulfillmentAttributes": {
      "@id": "aafa:AgriAdvisoryFulfillmentAttributes"
    },
    "deliveryMode": {
      "@id": "aafa:deliveryMode"
    },
    "targetLocation": {
      "@id": "aafa:targetLocation",
      "@type": "@id"
    },
    "targetRegionRadiusKm": {
      "@id": "aafa:targetRegionRadiusKm"
    },
    "requestedLanguage": {
      "@id": "schema:inLanguage"
    },
    "contentAccessUrl": {
      "@id": "schema:contentUrl"
    },
    "contentAccessExpiry": {
      "@id": "schema:expires"
    },
    "deliveryConfirmation": {
      "@id": "schema:confirmationNumber"
    },
    "priceQueryTimeRange": {
      "@id": "aafa:priceQueryTimeRange",
      "@type": "@id"
    },
    "DeliveryMode": "aafa:DeliveryMode"
  }
}
