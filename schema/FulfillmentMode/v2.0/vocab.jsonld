    "@graph": [
        {
            "@id": "beckn:FulfillmentMode",
            "rdfs:label": "Fulfillment Mode",
            "@type": "rdfs:Class",
            "rdfs:comment": "Describes the mode of fulfillment. This is an extensible container allowing domain-specific fulfillment modes to be expressed via attributes."
        },
        {
            "@id": "beckn:modeAttributes",
            "rdfs:label": "mode Attributes",
            "rdfs:domain": [
                "beckn:FulfillmentMode"
            ],
            "schema:rangeIncludes": "beckn:Attributes",
            "@type": "rdf:Property",
            "rdfs:comment": "Domain-specific fulfillment mode attributes (e.g., delivery, pickup, reservation, digital)"
        }
    ]
