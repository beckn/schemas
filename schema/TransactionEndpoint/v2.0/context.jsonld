{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/schema/core/v2.1/",
        "Action": {
            "@id": "beckn:Action",
            "@type": "@id",
            "@context": {
                "discover": "beckn:DiscoverAction",
                "on_discover": "beckn:OnDiscoverAction",
                "select": "beckn:SelectAction",
                "on_select": "beckn:OnSelectAction",
                "init": "beckn:InitAction",
                "on_init": "beckn:OnInitAction",
                "confirm": "beckn:ConfirmAction",
                "on_confirm": "beckn:OnConfirmAction",
                "status": "beckn:StatusAction",
                "on_status": "beckn:OnStatusAction",
                "update": "beckn:UpdateAction",
                "on_update": "beckn:OnUpdateAction",
                "cancel": "beckn:CancelAction",
                "on_cancel": "beckn:OnCancelAction",
                "track": "beckn:TrackAction",
                "on_track": "beckn:OnTrackAction",
                "rate": "beckn:RateAction",
                "on_rate": "beckn:OnRateAction",
                "support": "beckn:SupportAction",
                "on_support": "beckn:OnSupportAction",
                "catalog/publish": "beckn:CatalogPublishAction",
                "catalog/on_publish": "beckn:CatalogOnPublishAction"
            }
        }
    }
}
