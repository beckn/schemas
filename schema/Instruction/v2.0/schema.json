{
  "$id": "https://schema.beckn.io/Instruction/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema definition for Instruction in the Beckn Protocol v2.0.1",
  "title": "Instruction",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string",
      "format": "uri",
      "default": "https://schema.beckn.io/Instruction/v2.0/context.jsonld"
    },
    "@type": {
      "type": "string",
      "enum": [
        "Instruction"
      ],
      "default": "Instruction"
    },
    "descriptor": {
      "$ref": "https://schema.beckn.io/Descriptor/v2.1/attributes.yaml"
    },
    "id": {
      "type": "string"
    },
    "validity": {
      "$ref": "https://schema.beckn.io/TimePeriod/v2.1/attributes.yaml"
    }
  },
  "required": [
    "@context",
    "@type",
    "id",
    "descriptor"
  ],
  "additionalProperties": false,
  "x-tags": [
    "common"
  ]
}
