{
    "@context": {
        "@version": 1.1,
        "beckn": "https://raw.githubusercontent.com/beckn/protocol-specifications-v2/refs/heads/draft/main/schema/core/v2/#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "schema": "https://schema.org/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "beckn:TrackingRequest",
            "rdfs:label": "Tracking Request",
            "@type": "rdfs:Class",
            "rdfs:comment": "TODO: Add Description of Property"
        },
        {
            "@id": "beckn:callbackUrl",
            "rdfs:label": "callback Url",
            "rdfs:domain": [
                "beckn:TrackingRequest"
            ],
            "schema:rangeIncludes": "schema:URL",
            "@type": "rdf:Property",
            "rdfs:comment": "Optional callback URL for streaming tracking coordinates/updates"
        },
        {
            "@id": "beckn:modeHint",
            "rdfs:label": "mode Hint",
            "rdfs:domain": [
                "beckn:TrackingRequest"
            ],
            "schema:rangeIncludes": "schema:Text",
            "@type": "rdf:Property",
            "rdfs:comment": "Optional delivery mode for the tracking handle."
        },
        {
            "@id": "beckn:trackingDataSchema",
            "rdfs:label": "tracking Data Schema",
            "rdfs:domain": [
                "beckn:TrackingRequest"
            ],
            "@type": "rdf:Property",
            "rdfs:comment": "A JSON Schema (2020-12) that describes the structure of trackingData payloads."
        }
    ]
}