    "offered_compensation_period": "beckn:offered_compensation_period",
    "candidate_response": "beckn:candidate_response",
    "CandidateResponse": "ehca:CandidateResponse",
    "OfferedCompensationPeriod": "ehca:OfferedCompensationPeriod",
    "EmployerHiringContractAttributes": "beckn:EmployerHiringContractAttributes",
    "city": "beckn:city",
    "country": "beckn:country",
    "region": "beckn:region"
  }
