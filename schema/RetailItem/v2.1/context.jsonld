{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "RetailItem": {
      "@id": "beckn:RetailItem",
      "@type": "rdfs:Class"
    },
    "resourceId": {
      "@id": "beckn:resourceId"
    },
    "lineId": {
      "@id": "beckn:lineId"
    },
    "offerId": {
      "@id": "beckn:offerId"
    },
    "price": {
      "@id": "beckn:price",
      "@type": "@id"
    },
    "quantity": {
      "@id": "beckn:quantity",
      "@type": "@id"
    },
    "credentials": {
      "@id": "beckn:credentials",
      "@container": "@list"
    }
  }
}
